{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": ["airbnb-base", "prettier"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "settings": {
    "import/core-modules": ["@jest/globals", "archiver", "mssql", "mssql/msnodesqlv8.js"]
  },
  "rules": {
    "no-console": [
      "warn",
      {
        "allow": ["log", "warn", "error"]
      }
    ],
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_"
      }
    ],
    "consistent-return": "error",
    "implicit-arrow-linebreak": "off",
    "func-names": "off",
    "import/extensions": [
      "error",
      "ignorePackages",
      {
        "js": "always"
      }
    ],
    "no-restricted-syntax": "off",
    "no-continue": "off",
    "import/no-extraneous-dependencies": [
      "error",
      {
        "packageDir": ["./"],
        "devDependencies": ["tests/**", "**/*.test.js", "**/*.spec.js", "jest.config.js"]
      }
    ],
    "camelcase": "off",
    "class-methods-use-this": "off",
    "default-param-last": "off",
    "import/no-cycle": "off",
    "import/prefer-default-export": "off",
    "max-classes-per-file": "off",
    "no-await-in-loop": "off",
    "no-bitwise": "off",
    "no-constant-condition": "off",
    "no-empty-function": "off",
    "no-nested-ternary": "off",
    "no-param-reassign": "off",
    "no-plusplus": "off",
    "no-promise-executor-return": "off",
    "no-shadow": "off",
    "no-use-before-define": "off",
    "no-useless-escape": "off",
    "no-underscore-dangle": "off",
    "prefer-template": "off"
  },
  "overrides": [
    {
      "files": ["src/components/**/*.js", "docker/frontend/**/*.js", "tests/e2e/**/*.js"],
      "env": {
        "browser": true
      },
      "rules": {
        "no-alert": "off",
        "no-restricted-globals": "off"
      }
    }
  ]
}
