/Internal Audit/ChecksToUsers                                                                                                                                                                                                                                                                                                                                                                                                            |ChecksToUsers                                                                                                                                                                                                                                                                                                                                                                                                                            |ChecksToUsers                                                                                                                                                                                                                                                  |Text                                                                                                |SELECT        Dealership, checkdate, AcctgCheckAmount, checkno, UserFirstName, UserLastName, PayeeName1, PayeeName2, check_address, check_city, check_state,                           check_zip, vendor_name1, vendor_name2, vendor_address1, vendor_city, vendor_state, vendor_zip, checktype, interfacecode, journalid, postingdate,  DATEADD (ms, postingtime, 0) postingtime,                           voidflag, check_name1match, check_name2match, vendor_name1match, vendor_name2match , UserLastName + UserFirstName as UserGroupBy FROM            vw_ChecksToUser where checkdate between @BegDate and @EndDate and dealership in (@Dealerships) and userlastname in (@UserLastName)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                
/Internal Audit/ChecksToUsers                                                                                                                                                                                                                                                                                                                                                                                                            |ChecksToUsers                                                                                                                                                                                                                                                                                                                                                                                                                            |Dealerships                                                                                                                                                                                                                                                    |Text                                                                                                |SELECT DISTINCT Dealership FROM            vw_ChecksToUser WHERE        (checkdate BETWEEN @BegDate AND @EndDate)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               
/Internal Audit/ChecksToUsers                                                                                                                                                                                                                                                                                                                                                                                                            |ChecksToUsers                                                                                                                                                                                                                                                                                                                                                                                                                            |UserLastName                                                                                                                                                                                                                                                   |Text                                                                                                |select distinct userlastname  FROM            vw_ChecksToUser where checkdate between @BegDate and @EndDate order by userlastname                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               
/JobStatusReports/SummaryReport                                                                                                                                                                                                                                                                                                                                                                                                          |SummaryReport                                                                                                                                                                                                                                                                                                                                                                                                                            |DS_AFScrape                                                                                                                                                                                                                                                    |StoredProcedure                                                                                     |AFScrape_JobStatus                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              
/JobStatusReports/SummaryReport                                                                                                                                                                                                                                                                                                                                                                                                          |SummaryReport                                                                                                                                                                                                                                                                                                                                                                                                                            |DS_D1SSIS02                                                                                                                                                                                                                                                    |Text                                                                                                |DECLARE @RUN_DATE1 int  =   convert(varchar(8),@date,112)   IF OBJECT_ID('tempdb..#temp') IS NOT NULL drop table #temp  SELECT  DISTINCT JOB.name ,CASE [dbo].fnCheckJobStatus_SSIS02( job.name  , @date) when 1 THEN 'Success'  else (  CASE  WHEN H.RUN_DATE = @RUN_DATE1 AND H.run_status = 1 THEN 'Success'      WHEN H.RUN_DATE = @RUN_DATE1 AND H.run_status = 0 THEN 'Failure'              --WHEN H.RUN_DATE = @RUN_DATE1 AND H.RUN_STATUS = 2 THEN 'Retry'             --WHEN H.RUN_DATE = @RUN_DATE1 AND H.RUN_STATUS = 3 THEN 'Cancelled'       WHEN GETDATE() <= next_scheduled_run_date THEN 'Yet to run'       WHEN H.RUN_DATE = @RUN_DATE1 and ACTIVITY.start_execution_date IS NOT NULL AND ACTIVITY.stop_execution_date IS NULL then 'Running'               ELSE 'Unknown'       END)      END  AS STATUS,                                         CASE WHEN run_date  < @RUN_DATE1  THEN CONVERT(VARCHAR(8),next_scheduled_run_date,112) ELSE RUN_DATE END AS RUN_DATE     INTO #TEMP      FROM  msdb.DBO.SYSJOBS_VIEW JOB(NOLOCK)--1             JOIN msdb.DBO.SYSJOBHISTORY H(NOLOCK) ON JOB.JOB_ID = H.JOB_ID --AND H.run_date = @RUN_DATE--2             JOIN msdb.DBO.SYSJOBACTIVITY ACTIVITY(NOLOCK) ON JOB.JOB_ID = ACTIVITY.JOB_ID--3             JOIN msdb.dbo.sysschedules ac ON ac.schedule_id = ac.schedule_id --4       AND INSTANCE_ID IN (        SELECT MAX(INSTANCE_ID) FROM  msdb.DBO.SYSJOBS_VIEW JOB(NOLOCK)--1                     JOIN msdb.DBO.SYSJOBHISTORY H(NOLOCK) ON JOB.JOB_ID = H.JOB_ID--2         WHERE (H.RUN_DATE  = @RUN_DATE1  OR  CONVERT(VARCHAR(8),next_scheduled_run_date,112) =@RUN_DATE1)        GROUP BY JOB.NAME, RUN_DATE     )         WHERE (H.RUN_DATE  = @RUN_DATE1 OR  CONVERT(VARCHAR(8),next_scheduled_run_date,112) = @RUN_DATE1)        AND JOB.ENABLED = 1   IF OBJECT_ID('tempdb..#FINAL') IS NOT NULL drop table #FINAL     SELECT * INTO #FINAL FROM (     SELECT DISTINCT NAME,'No Run' AS STATUS,NULL AS RUN_DATE FROM msdb.DBO.SYSJOBS_VIEW (NOLOCK)--1                 WHERE NAME NOT IN (SELECT DISTINCT NAME FROM #TEMP)  AND ENABLED = 1 -- FOR NOT RUNNING JOBS         UNION         SELECT * FROM #TEMP     )A  select name, case when row  = 2 then 'Yet to run(Multiple Run)' else status end as status from ( SELECT  name,status,row_number()over(partition by name order by status) as row FROM #FINAL where status != 'No Run' )a order by Status                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  
/JobStatusReports/SummaryReport                                                                                                                                                                                                                                                                                                                                                                                                          |SummaryReport                                                                                                                                                                                                                                                                                                                                                                                                                            |SSIS01ReportDataset                                                                                                                                                                                                                                            |Text                                                                                                | DECLARE @RUN_DATE1 int  =   convert(varchar(8),@date,112)   IF OBJECT_ID('tempdb..#temp') IS NOT NULL drop table #temp  SELECT  DISTINCT JOB.name , CASE [dbo].fnCheckJobStatus_SSIS01( job.name  , @date) when 1 THEN 'Success'  else (  CASE  WHEN H.RUN_DATE = @RUN_DATE1 AND H.run_status = 1 THEN 'Success'      WHEN H.RUN_DATE = @RUN_DATE1 AND H.run_status = 0 THEN 'Failure'              --WHEN H.RUN_DATE = @RUN_DATE1 AND H.RUN_STATUS = 2 THEN 'Retry'             --WHEN H.RUN_DATE = @RUN_DATE1 AND H.RUN_STATUS = 3 THEN 'Cancelled'       WHEN GETDATE() <= next_scheduled_run_date THEN 'Yet to run'       WHEN H.RUN_DATE = @RUN_DATE1 and ACTIVITY.start_execution_date IS NOT NULL AND ACTIVITY.stop_execution_date IS NULL then 'Running'               ELSE 'Unknown'      END)      END  AS STATUS,                                         CASE WHEN run_date  < @RUN_DATE1  THEN CONVERT(VARCHAR(8),next_scheduled_run_date,112) ELSE RUN_DATE END AS RUN_DATE     INTO #TEMP      FROM  msdb.DBO.SYSJOBS_VIEW JOB(NOLOCK)--1             JOIN msdb.DBO.SYSJOBHISTORY H(NOLOCK) ON JOB.JOB_ID = H.JOB_ID --AND H.run_date = @RUN_DATE--2             JOIN msdb.DBO.SYSJOBACTIVITY ACTIVITY(NOLOCK) ON JOB.JOB_ID = ACTIVITY.JOB_ID--3             JOIN msdb.dbo.sysschedules ac ON ac.schedule_id = ac.schedule_id --4       AND INSTANCE_ID IN (        SELECT MAX(INSTANCE_ID) FROM  msdb.DBO.SYSJOBS_VIEW JOB(NOLOCK)--1                     JOIN msdb.DBO.SYSJOBHISTORY H(NOLOCK) ON JOB.JOB_ID = H.JOB_ID--2         WHERE (H.RUN_DATE  = @RUN_DATE1  OR  CONVERT(VARCHAR(8),next_scheduled_run_date,112) =@RUN_DATE1)        GROUP BY JOB.NAME, RUN_DATE     )         WHERE (H.RUN_DATE  = @RUN_DATE1 OR  CONVERT(VARCHAR(8),next_scheduled_run_date,112) = @RUN_DATE1)        AND JOB.ENABLED = 1   IF OBJECT_ID('tempdb..#FINAL') IS NOT NULL drop table #FINAL     SELECT * INTO #FINAL FROM (     SELECT DISTINCT NAME,'No Run' AS STATUS,NULL AS RUN_DATE FROM msdb.DBO.SYSJOBS_VIEW (NOLOCK)--1                 WHERE NAME NOT IN (SELECT DISTINCT NAME FROM #TEMP)  AND ENABLED = 1 -- FOR NOT RUNNING JOBS         UNION         SELECT * FROM #TEMP     )A  select name, case when row  = 2 then 'Yet to run(Multiple Run)' else status end as status from ( SELECT  name,status,row_number()over(partition by name order by status) as row FROM #FINAL where status != 'No Run' )a order by Status                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 
/Legal/TrueCar Emails                                                                                                                                                                                                                                                                                                                                                                                                                    |TrueCar Emails                                                                                                                                                                                                                                                                                                                                                                                                                           |Emails                                                                                                                                                                                                                                                         |Text                                                                                                |SELECT [lPersonID]       ,[lcompanyid]       ,[ADPCustNO]       ,[OpportunityID]       ,[lCurrentOwnerID]       ,[TaskID]       ,[szTo]       ,[szFrom]       ,[szSubject]       ,[DueDate]       ,[dtcompleted]       ,[dtClosed]       ,[dtLastEdit]       ,[NextActivityType]       ,[NextActivitySubject]       ,[NextActivityDueDate]       ,[NextActivityComments]       ,[attachments]       ,[EmailInboundOutbound]       ,[WorkflowType]       ,[WorkflowName]       ,[ActivityTask]       ,[EmailNotes]       ,[szSource]       ,[szSubSource]       ,[TemplateName]       ,[IsEmailTemplate]       ,[DEALERSHIP]       ,[xEmailBody]   FROM [BI_WorkDB].[dbo].[tbl_LegalTC_Emails_mid]                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               
/New Inventory - Count By Make Model Dealership                                                                                                                                                                                                                                                                                                                                                                                          |New Inventory - Count By Make Model Dealership                                                                                                                                                                                                                                                                                                                                                                                           |DistList                                                                                                                                                                                                                                                       |Text                                                                                                |SELECT     r.EMailAddress, r.Role, r.RVPEmailAddress,                        r.RCtrlEmailAddress, nid.WebVID, nid.Region,                        nid.Store, nid.ADPID, 'New Inventory - ' + ' ' + nid.store as Subject FROM         tblRecipients r INNER JOIN vw_NewInvDist nid ON r.DMSCompanyID = nid.adpid where r.Role = 'GM'                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              
/New Inventory - Count By Make Model Dealership                                                                                                                                                                                                                                                                                                                                                                                          |New Inventory - Count By Make Model Dealership                                                                                                                                                                                                                                                                                                                                                                                           |NewInventory                                                                                                                                                                                                                                                   |Text                                                                                                |with EntryDate as (select companyid,control,min(dateofoldestscheditem) DOOSI from dms.dbo.glschedule where currentmonth > DATEADD(dd,-75,getdate()) and right(accountnumber,4) in ('2320','2300','2340','2341','2342') group by companyid,control )  , companyidLkp as  (SELECT distinct   [CompanyID]   ,[WebV_ID]   FROM [BI_WorkDB].[dbo].[vw_ADP_CoID_WebV_Link])  SELECT     d.AccountingName, d.Region, vi.stk_nbr, vi.mod_yr2,   case when vi.make_desc2 like '%mercedes%' then 'Mercedes Benz' else vi.make_desc2 end make_desc2   , vi.mod_desc2, vi.extr_color_desc2, vi.intr_color_desc2, vi.cur_odo_rd_nbr,                        vi.srs_desc2, DATEDIFF(d, e.DOOSI, GETDATE()) AS DaysInStock, vi.dflt_slng_price_amt, vi.tot_list_amt,                        vi.dflt_slng_price_amt - vi.acctg_cost_amt AS Margin,         CASE WHEN datediff(d, e.DOOSI, getdate()) > 365 THEN '366+ Days'         WHEN datediff(d, e.DOOSI, getdate()) > 275 THEN '276-365 Days'         WHEN datediff(d, e.DOOSI, getdate()) > 180 THEN '181-275 Days'         WHEN datediff(d, e.DOOSI, getdate()) > 90 THEN '91-180 Days'         ELSE '0-90 Days' END AS AgingBucket,  CASE WHEN datediff(d, e.DOOSI, getdate()) > 365 THEN 1 WHEN datediff(d,                        e.DOOSI, getdate()) > 275 THEN 2 WHEN datediff(d, e.DOOSI, getdate()) > 180 THEN 3 WHEN datediff(d, e.DOOSI, getdate())                        > 90 THEN 4 ELSE 5 END AS AgingBucketSrt, RIGHT(vi.elt_inv_acct, 4) AS AcctNo FROM         [206.22.183.247].SonicWebV_veh.dbo.veh_inventory AS vi (nolock) INNER JOIN                       vw_ADP_CoID_WebV_Link_wv AS d ON d.WebV_ID = vi.loc_id  inner join companyidLkp c on c.webv_id =d.webv_id                       inner join EntryDate e on vi.stk_nbr = e.control and e.companyid = c.companyid WHERE     (vi.inv_stat_cd = 'INS') AND (vi.del_flg = 0) AND (vi.new_veh_flg = 1) AND (acctg_cost_amt > 1000) AND (vi.loc_id IN (@Stores)) AND                        (NOT (RIGHT(vi.elt_inv_acct, 4) IN ('2605', '2600')))and ((d.AccountingName='Tom Williams Porsche/Audi' and left(vi.elt_inv_acct,1) in ('2','3')) or   (d.AccountingName='Tom Williams BMW/MINI' and left(vi.elt_inv_acct,1) in ('1','5')) or   (d.AccountingName='BMW of Ann Arbor' and left(vi.elt_inv_acct,1) in ('1')) or   (d.AccountingName='Mercedes of Ann Arbor' and left(vi.elt_inv_acct,1) in ('2'))  or d.AccountingName not in ('Tom Williams Porsche/Audi'    ,'Tom Williams BMW/MINI'    ,'BMW of Ann Arbor'    ,'Mercedes of Ann Arbor' ,'Porsche Audi West Houston'))   and not   (d.AccountingName='Global Imports' and make_desc2 ='MINI')  and not   (d.AccountingName='Global MINI' and make_desc2 = 'BMW')   and not   (d.AccountingName='BMW & Mini of Nashville' and make_desc2 ='MINI')  and not   (d.AccountingName='BMW MINI of Nashville' and make_desc2 = 'BMW')   --and vin2 = '3FA6P0H75DR102655' ORDER BY vi.make_desc2, stk_nbr, vin2, d.AccountingName, last_chng_dttm DESC                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        
/New Inventory - Count By Make Model Dealership                                                                                                                                                                                                                                                                                                                                                                                          |New Inventory - Count By Make Model Dealership                                                                                                                                                                                                                                                                                                                                                                                           |Regions                                                                                                                                                                                                                                                        |Text                                                                                                |SELECT DISTINCT Region FROM         vw_ADP_CoID_WebV_Link                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       
/New Inventory - Count By Make Model Dealership                                                                                                                                                                                                                                                                                                                                                                                          |New Inventory - Count By Make Model Dealership                                                                                                                                                                                                                                                                                                                                                                                           |StoresAvailable                                                                                                                                                                                                                                                |Text                                                                                                |SELECT DISTINCT AccountingName, WebV_ID FROM            vw_ADP_CoID_WebV_Link_wv WHERE        (Region IN (@Regions)) ORDER BY AccountingName                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
/New Vehicles/New Inventory - Playbook - All_exp                                                                                                                                                                                                                                                                                                                                                                                         |New Inventory - Playbook - All_exp                                                                                                                                                                                                                                                                                                                                                                                                       |DistList                                                                                                                                                                                                                                                       |Text                                                                                                |SELECT     r.EMailAddress, r.Role, r.RVPEmailAddress,                        r.RCtrlEmailAddress, nid.WebVID, nid.Region,                        nid.Store, nid.ADPID, 'New Inventory - ' + ' ' + nid.store as Subject FROM         tblRecipients r INNER JOIN vw_NewInvDist nid ON r.DMSCompanyID = nid.adpid where r.Role = 'GM'                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              
/New Vehicles/New Inventory - Playbook - All_exp                                                                                                                                                                                                                                                                                                                                                                                         |New Inventory - Playbook - All_exp                                                                                                                                                                                                                                                                                                                                                                                                       |NewInventory                                                                                                                                                                                                                                                   |Text                                                                                                |with EntryDate as (select companyid,control,min(dateofoldestscheditem) DOOSI from dms.dbo.glschedule where currentmonth > DATEADD(dd,-75,getdate()) and right(accountnumber,4) in ('2320','2300','2340','2341','2342') group by companyid,control )  , companyidLkp as  (SELECT distinct   [CompanyID]   ,[WebV_ID]   FROM [BI_WorkDB].[dbo].[vw_ADP_CoID_WebV_Link])  SELECT     d.AccountingName, d.Region, vi.stk_nbr, vi.mod_yr2, vi.make_desc2, vi.mod_desc2, vi.extr_color_desc2, vi.intr_color_desc2, vi.cur_odo_rd_nbr,                        vi.srs_desc2, DATEDIFF(d, e.DOOSI, GETDATE()) AS DaysInStock, vi.dflt_slng_price_amt, vi.tot_list_amt,                        vi.dflt_slng_price_amt - vi.acctg_cost_amt AS Margin, CASE WHEN datediff(d, e.DOOSI, getdate()) > 365 THEN '366+ Days' WHEN datediff(d, e.DOOSI,                        getdate()) > 210 THEN '211-365 Days' WHEN datediff(d, e.DOOSI, getdate()) > 150 THEN '150-210 Days' WHEN datediff(d, e.DOOSI, getdate())                        > 60 THEN '61-150 Days' ELSE '0-60 Days' END AS AgingBucket, CASE WHEN datediff(d, e.DOOSI, getdate()) > 365 THEN 1 WHEN datediff(d,                        e.DOOSI, getdate()) > 210 THEN 2 WHEN datediff(d, e.DOOSI, getdate()) > 150 THEN 3 WHEN datediff(d, e.DOOSI, getdate())                        > 60 THEN 4 ELSE 5 END AS AgingBucketSrt, RIGHT(vi.elt_inv_acct, 4) AS AcctNo FROM         [206.22.183.210].SonicWebV_veh.dbo.veh_inventory AS vi (nolock) INNER JOIN                       vw_ADP_CoID_WebV_Link_wv AS d ON d.WebV_ID = vi.loc_id  inner join companyidLkp c on c.webv_id =d.webv_id                       inner join EntryDate e on vi.stk_nbr = e.control and e.companyid = c.companyid WHERE     (vi.inv_stat_cd = 'INS') AND (vi.del_flg = 0) AND (vi.new_veh_flg = 1) AND (acctg_cost_amt > 1000) AND (vi.loc_id IN (@Stores)) AND                        (NOT (RIGHT(vi.elt_inv_acct, 4) IN ('2605', '2600')))and ((d.AccountingName='Tom Williams Porsche/Audi' and left(vi.elt_inv_acct,1) in ('2','3')) or   (d.AccountingName='Tom Williams BMW/MINI' and left(vi.elt_inv_acct,1) in ('1','5')) or   (d.AccountingName='BMW of Ann Arbor' and left(vi.elt_inv_acct,1) in ('1')) or   (d.AccountingName='Mercedes of Ann Arbor' and left(vi.elt_inv_acct,1) in ('2'))  or d.AccountingName not in ('Tom Williams Porsche/Audi'    ,'Tom Williams BMW/MINI'    ,'BMW of Ann Arbor'    ,'Mercedes of Ann Arbor' ,'Porsche Audi West Houston'))   and not   (d.AccountingName='Global Imports' and make_desc2 ='MINI')  and not   (d.AccountingName='Global MINI' and make_desc2 = 'BMW')   --and vin2 = '3FA6P0H75DR102655' ORDER BY vi.make_desc2, stk_nbr, vin2, d.AccountingName, last_chng_dttm DESC                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        
/New Vehicles/New Inventory - Playbook - All_exp                                                                                                                                                                                                                                                                                                                                                                                         |New Inventory - Playbook - All_exp                                                                                                                                                                                                                                                                                                                                                                                                       |Regions                                                                                                                                                                                                                                                        |Text                                                                                                |SELECT DISTINCT Region FROM         vw_ADP_CoID_WebV_Link                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       
/New Vehicles/New Inventory - Playbook - All_exp                                                                                                                                                                                                                                                                                                                                                                                         |New Inventory - Playbook - All_exp                                                                                                                                                                                                                                                                                                                                                                                                       |StoresAvailable                                                                                                                                                                                                                                                |Text                                                                                                |SELECT DISTINCT AccountingName, WebV_ID FROM            vw_ADP_CoID_WebV_Link_wv WHERE        (Region IN (@Regions)) ORDER BY AccountingName                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
/New Vehicles/New Inventory - Pricing - All_exp                                                                                                                                                                                                                                                                                                                                                                                          |New Inventory - Pricing - All_exp                                                                                                                                                                                                                                                                                                                                                                                                        |DistList                                                                                                                                                                                                                                                       |Text                                                                                                |SELECT     r.EMailAddress, r.Role, r.RVPEmailAddress,                        r.RCtrlEmailAddress, nid.WebVID, nid.Region,                        nid.Store, nid.ADPID, 'New Inventory - ' + ' ' + nid.store as Subject FROM         tblRecipients r INNER JOIN vw_NewInvDist nid ON r.DMSCompanyID = nid.adpid where r.Role = 'GM'                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              
/New Vehicles/New Inventory - Pricing - All_exp                                                                                                                                                                                                                                                                                                                                                                                          |New Inventory - Pricing - All_exp                                                                                                                                                                                                                                                                                                                                                                                                        |NewInventory                                                                                                                                                                                                                                                   |Text                                                                                                |with EntryDate as (select companyid,control,min(dateofoldestscheditem) DOOSI from dms.dbo.glschedule where currentmonth > DATEADD(dd,-75,getdate()) and right(accountnumber,4) in ('2320','2300','2340','2341','2342') group by companyid,control )  , companyidLkp as  (SELECT distinct   [CompanyID]   ,[WebV_ID]   FROM [BI_WorkDB].[dbo].[vw_ADP_CoID_WebV_Link])  SELECT     d.AccountingName, d.Region, vi.stk_nbr, vi.mod_yr2, vi.make_desc2, vi.mod_desc2, vi.extr_color_desc2, vi.intr_color_desc2, vi.cur_odo_rd_nbr,                        vi.srs_desc2, DATEDIFF(d, e.DOOSI, GETDATE()) AS DaysInStock, vi.dflt_slng_price_amt, vi.tot_list_amt,                        vi.dflt_slng_price_amt - vi.acctg_cost_amt AS Margin, CASE WHEN datediff(d, e.DOOSI, getdate()) > 365 THEN '366+ Days' WHEN datediff(d, e.DOOSI,                        getdate()) > 210 THEN '211-365 Days' WHEN datediff(d, e.DOOSI, getdate()) > 150 THEN '150-210 Days' WHEN datediff(d, e.DOOSI, getdate())                        > 60 THEN '61-150 Days' ELSE '0-60 Days' END AS AgingBucket, CASE WHEN datediff(d, e.DOOSI, getdate()) > 365 THEN 1 WHEN datediff(d,                        e.DOOSI, getdate()) > 210 THEN 2 WHEN datediff(d, e.DOOSI, getdate()) > 150 THEN 3 WHEN datediff(d, e.DOOSI, getdate())                        > 60 THEN 4 ELSE 5 END AS AgingBucketSrt, RIGHT(vi.elt_inv_acct, 4) AS AcctNo, vi.invc_tot_list_amt, vi.tot_cost_amt FROM         [206.22.183.210].SonicWebV_veh.dbo.veh_inventory AS vi (nolock) INNER JOIN                       vw_ADP_CoID_WebV_Link_wv AS d ON d.WebV_ID = vi.loc_id  inner join companyidLkp c on c.webv_id =d.webv_id                       inner join EntryDate e on vi.stk_nbr = e.control and e.companyid = c.companyid WHERE     (vi.inv_stat_cd = 'INS') AND (vi.del_flg = 0) AND (vi.new_veh_flg = 1) AND (acctg_cost_amt > 1000) AND (vi.loc_id IN (@Stores)) AND                        (NOT (RIGHT(vi.elt_inv_acct, 4) IN ('2605', '2600')))and ((d.AccountingName='Tom Williams Porsche/Audi' and left(vi.elt_inv_acct,1) in ('2','3')) or   (d.AccountingName='Tom Williams BMW/MINI' and left(vi.elt_inv_acct,1) in ('1','5')) or   (d.AccountingName='BMW of Ann Arbor' and left(vi.elt_inv_acct,1) in ('1')) or   (d.AccountingName='Mercedes of Ann Arbor' and left(vi.elt_inv_acct,1) in ('2'))  or d.AccountingName not in ('Tom Williams Porsche/Audi'    ,'Tom Williams BMW/MINI'    ,'BMW of Ann Arbor'    ,'Mercedes of Ann Arbor' ,'Porsche Audi West Houston'))   and not   (d.AccountingName='Global Imports' and make_desc2 ='MINI')  and not   (d.AccountingName='Global MINI' and make_desc2 = 'BMW')   --and vin2 = '3FA6P0H75DR102655' ORDER BY vi.make_desc2, stk_nbr, vin2, d.AccountingName, last_chng_dttm DESC                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 
/New Vehicles/New Inventory - Pricing - All_exp                                                                                                                                                                                                                                                                                                                                                                                          |New Inventory - Pricing - All_exp                                                                                                                                                                                                                                                                                                                                                                                                        |Regions                                                                                                                                                                                                                                                        |Text                                                                                                |SELECT DISTINCT Region FROM         vw_ADP_CoID_WebV_Link                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       
/New Vehicles/New Inventory - Pricing - All_exp                                                                                                                                                                                                                                                                                                                                                                                          |New Inventory - Pricing - All_exp                                                                                                                                                                                                                                                                                                                                                                                                        |StoresAvailable                                                                                                                                                                                                                                                |Text                                                                                                |SELECT DISTINCT AccountingName, WebV_ID FROM            vw_ADP_CoID_WebV_Link_wv WHERE        (Region IN (@Regions)) ORDER BY AccountingName                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
