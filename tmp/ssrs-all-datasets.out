/BI - New Vehicles/Archive/New Inventory - Playbook - All_exp_Playbook                                                                                                                                                                                                                                                                                                                                                                   |New Inventory - Playbook - All_exp_Playbook                                                                                                                                                                                                                                                                                                                                                                                              |StoresAvailable                                                                                                                                                                                                                                                |Text                                                                                                |SELECT DISTINCT AccountingName, WebV_ID FROM            vw_ADP_CoID_WebV_Link_wv WHERE        (Region IN (@Regions)) ORDER BY AccountingName                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
/BI - New Vehicles/Archive/New Inventory - Playbook - All_exp_Playbook_strpd                                                                                                                                                                                                                                                                                                                                                             |New Inventory - Playbook - All_exp_Playbook_strpd                                                                                                                                                                                                                                                                                                                                                                                        |DistList                                                                                                                                                                                                                                                       |Text                                                                                                |SELECT     r.EMailAddress, r.Role, r.RVPEmailAddress,                        r.RCtrlEmailAddress, nid.WebVID, nid.Region,                        nid.Store, nid.ADPID, 'New Inventory - ' + ' ' + nid.store as Subject FROM         tblRecipients r INNER JOIN vw_NewInvDist nid ON r.DMSCompanyID = nid.adpid where r.Role = 'GM'                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              
/BI - New Vehicles/Archive/New Inventory - Playbook - All_exp_Playbook_strpd                                                                                                                                                                                                                                                                                                                                                             |New Inventory - Playbook - All_exp_Playbook_strpd                                                                                                                                                                                                                                                                                                                                                                                        |NewInventory                                                                                                                                                                                                                                                   |Text                                                                                                |with EntryDate as (select companyid,control,min(dateofoldestscheditem) DOOSI from dms.dbo.glschedule where currentmonth > DATEADD(dd,-75,getdate()) and right(accountnumber,4) in ('2320','2300','2340','2341','2342') group by companyid,control )  , companyidLkp as  (SELECT distinct   [CompanyID]   ,[WebV_ID]   FROM [BI_WorkDB].[dbo].[vw_ADP_CoID_WebV_Link])  SELECT     d.AccountingName, d.Region, vi.stk_nbr, vi.mod_yr2, vi.make_desc2, vi.mod_desc2, vi.extr_color_desc2, vi.intr_color_desc2, vi.cur_odo_rd_nbr,                        vi.srs_desc2, DATEDIFF(d, e.DOOSI, GETDATE()) AS DaysInStock, vi.dflt_slng_price_amt, vi.tot_list_amt,                        vi.dflt_slng_price_amt - vi.acctg_cost_amt AS Margin, CASE WHEN datediff(d, e.DOOSI, getdate()) > 365 THEN '366+ Days' WHEN datediff(d, e.DOOSI,                        getdate()) > 210 THEN '211-365 Days' WHEN datediff(d, e.DOOSI, getdate()) > 150 THEN '150-210 Days' WHEN datediff(d, e.DOOSI, getdate())                        > 90 THEN '91-150 Days' ELSE '0-90 Days' END AS AgingBucket,  CASE WHEN datediff(d, e.DOOSI, getdate()) > 365 THEN 1 WHEN datediff(d,                        e.DOOSI, getdate()) > 210 THEN 2 WHEN datediff(d, e.DOOSI, getdate()) > 150 THEN 3 WHEN datediff(d, e.DOOSI, getdate())                        > 90 THEN 4 ELSE 5 END AS AgingBucketSrt, RIGHT(vi.elt_inv_acct, 4) AS AcctNo FROM         [206.22.183.247].SonicWebV_veh.dbo.veh_inventory AS vi (nolock) INNER JOIN                       vw_ADP_CoID_WebV_Link_wv AS d ON d.WebV_ID = vi.loc_id  inner join companyidLkp c on c.webv_id =d.webv_id                       inner join EntryDate e on vi.stk_nbr = e.control and e.companyid = c.companyid WHERE     (vi.inv_stat_cd = 'INS') AND (vi.del_flg = 0) AND (vi.new_veh_flg = 1) AND (acctg_cost_amt > 1000) AND (vi.loc_id IN (@Stores)) AND                        (NOT (RIGHT(vi.elt_inv_acct, 4) IN ('2605', '2600')))and ((d.AccountingName='Tom Williams Porsche/Audi' and left(vi.elt_inv_acct,1) in ('2','3')) or   (d.AccountingName='Tom Williams BMW/MINI' and left(vi.elt_inv_acct,1) in ('1','5')) or   (d.AccountingName='BMW of Ann Arbor' and left(vi.elt_inv_acct,1) in ('1')) or   (d.AccountingName='Mercedes of Ann Arbor' and left(vi.elt_inv_acct,1) in ('2'))  or d.AccountingName not in ('Tom Williams Porsche/Audi'    ,'Tom Williams BMW/MINI'    ,'BMW of Ann Arbor'    ,'Mercedes of Ann Arbor' ,'Porsche Audi West Houston'))   and not   (d.AccountingName='Global Imports' and make_desc2 ='MINI')  and not   (d.AccountingName='Global MINI' and make_desc2 = 'BMW')   and not   (d.AccountingName='BMW & Mini of Nashville' and make_desc2 ='MINI')  and not   (d.AccountingName='BMW MINI of Nashville' and make_desc2 = 'BMW')   --and vin2 = '3FA6P0H75DR102655' ORDER BY vi.make_desc2, stk_nbr, vin2, d.AccountingName, last_chng_dttm DESC                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          
/BI - New Vehicles/Archive/New Inventory - Playbook - All_exp_Playbook_strpd                                                                                                                                                                                                                                                                                                                                                             |New Inventory - Playbook - All_exp_Playbook_strpd                                                                                                                                                                                                                                                                                                                                                                                        |Regions                                                                                                                                                                                                                                                        |Text                                                                                                |SELECT DISTINCT Region FROM         vw_ADP_CoID_WebV_Link                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       
/BI - New Vehicles/Archive/New Inventory - Playbook - All_exp_Playbook_strpd                                                                                                                                                                                                                                                                                                                                                             |New Inventory - Playbook - All_exp_Playbook_strpd                                                                                                                                                                                                                                                                                                                                                                                        |StoresAvailable                                                                                                                                                                                                                                                |Text                                                                                                |SELECT DISTINCT AccountingName, WebV_ID FROM            vw_ADP_CoID_WebV_Link_wv WHERE        (Region IN (@Regions)) ORDER BY AccountingName                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
/BI - New Vehicles/Archive/New Inventory - Pricing - All_exp                                                                                                                                                                                                                                                                                                                                                                             |New Inventory - Pricing - All_exp                                                                                                                                                                                                                                                                                                                                                                                                        |DistList                                                                                                                                                                                                                                                       |Text                                                                                                |SELECT     r.EMailAddress, r.Role, r.RVPEmailAddress,                        r.RCtrlEmailAddress, nid.WebVID, nid.Region,                        nid.Store, nid.ADPID, 'New Inventory - ' + ' ' + nid.store as Subject FROM         tblRecipients r INNER JOIN [P10-SPSQLENT02\SPSQLENT02DB].buisnessintelligence.dbo.vw_NewInvDist nid ON r.DMSCompanyID = nid.adpid where r.Role = 'GM'                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       
/BI - New Vehicles/Archive/New Inventory - Pricing - All_exp                                                                                                                                                                                                                                                                                                                                                                             |New Inventory - Pricing - All_exp                                                                                                                                                                                                                                                                                                                                                                                                        |NewInventory                                                                                                                                                                                                                                                   |Text                                                                                                |with EntryDate as (select companyid,control,min(dateofoldestscheditem) DOOSI from dms.dbo.glschedule where currentmonth > DATEADD(dd,-75,getdate()) and right(accountnumber,4) in ('2320','2300','2340','2341','2342') group by companyid,control )  , companyidLkp as  (SELECT distinct   [CompanyID]   ,[WebV_ID]   FROM [BI_WorkDB].[dbo].[vw_ADP_CoID_WebV_Link])  SELECT     d.AccountingName, d.Region, vi.stk_nbr, vi.mod_yr2, vi.make_desc2, vi.mod_desc2, vi.extr_color_desc2, vi.intr_color_desc2, vi.cur_odo_rd_nbr,                        vi.srs_desc2, DATEDIFF(d, e.DOOSI, GETDATE()) AS DaysInStock, vi.dflt_slng_price_amt, vi.tot_list_amt,                        vi.dflt_slng_price_amt - vi.acctg_cost_amt AS Margin, CASE WHEN datediff(d, e.DOOSI, getdate()) > 365 THEN '366+ Days' WHEN datediff(d, e.DOOSI,                        getdate()) > 210 THEN '211-365 Days' WHEN datediff(d, e.DOOSI, getdate()) > 150 THEN '150-210 Days' WHEN datediff(d, e.DOOSI, getdate())                        > 60 THEN '61-150 Days' ELSE '0-60 Days' END AS AgingBucket, CASE WHEN datediff(d, e.DOOSI, getdate()) > 365 THEN 1 WHEN datediff(d,                        e.DOOSI, getdate()) > 210 THEN 2 WHEN datediff(d, e.DOOSI, getdate()) > 150 THEN 3 WHEN datediff(d, e.DOOSI, getdate())                        > 60 THEN 4 ELSE 5 END AS AgingBucketSrt, RIGHT(vi.elt_inv_acct, 4) AS AcctNo, vi.invc_tot_list_amt, vi.tot_cost_amt FROM         [206.22.183.247].SonicWebV_veh.dbo.veh_inventory AS vi (nolock) INNER JOIN                       vw_ADP_CoID_WebV_Link_wv AS d ON d.WebV_ID = vi.loc_id  inner join companyidLkp c on c.webv_id =d.webv_id                       inner join EntryDate e on vi.stk_nbr = e.control and e.companyid = c.companyid WHERE     (vi.inv_stat_cd = 'INS') AND (vi.del_flg = 0) AND (vi.new_veh_flg = 1) AND (acctg_cost_amt > 1000) AND (vi.loc_id IN (@Stores)) AND                        (NOT (RIGHT(vi.elt_inv_acct, 4) IN ('2605', '2600')))and ((d.AccountingName='Tom Williams Porsche/Audi' and left(vi.elt_inv_acct,1) in ('2','3')) or   (d.AccountingName='Tom Williams BMW/MINI' and left(vi.elt_inv_acct,1) in ('1','5')) or   (d.AccountingName='BMW of Ann Arbor' and left(vi.elt_inv_acct,1) in ('1')) or   (d.AccountingName='Mercedes of Ann Arbor' and left(vi.elt_inv_acct,1) in ('2'))  or d.AccountingName not in ('Tom Williams Porsche/Audi'    ,'Tom Williams BMW/MINI'    ,'BMW of Ann Arbor'    ,'Mercedes of Ann Arbor' ,'Porsche Audi West Houston'))   and not   (d.AccountingName='Global Imports' and make_desc2 ='MINI')  and not   (d.AccountingName='Global MINI' and make_desc2 = 'BMW')   --and vin2 = '3FA6P0H75DR102655' ORDER BY vi.make_desc2, stk_nbr, vin2, d.AccountingName, last_chng_dttm DESC                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 
/BI - New Vehicles/Archive/New Inventory - Pricing - All_exp                                                                                                                                                                                                                                                                                                                                                                             |New Inventory - Pricing - All_exp                                                                                                                                                                                                                                                                                                                                                                                                        |Regions                                                                                                                                                                                                                                                        |Text                                                                                                |SELECT DISTINCT Region FROM         vw_ADP_CoID_WebV_Link                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       
/BI - New Vehicles/Archive/New Inventory - Pricing - All_exp                                                                                                                                                                                                                                                                                                                                                                             |New Inventory - Pricing - All_exp                                                                                                                                                                                                                                                                                                                                                                                                        |StoresAvailable                                                                                                                                                                                                                                                |Text                                                                                                |SELECT DISTINCT AccountingName, WebV_ID FROM            vw_ADP_CoID_WebV_Link_wv WHERE        (Region IN (@Regions)) ORDER BY AccountingName                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
/BI - New Vehicles/Archive/New Playbook - Pre Visit                                                                                                                                                                                                                                                                                                                                                                                      |New Playbook - Pre Visit                                                                                                                                                                                                                                                                                                                                                                                                                 |Dealerships                                                                                                                                                                                                                                                    |Text                                                                                                |select * from vw_ADP_CoID_WebV_Link_wv order by accountingname                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  
/BI - New Vehicles/Archive/New Playbook - Pre Visit                                                                                                                                                                                                                                                                                                                                                                                      |New Playbook - Pre Visit                                                                                                                                                                                                                                                                                                                                                                                                                 |New_Inventory                                                                                                                                                                                                                                                  |Text                                                                                                |with EntryDate as (select companyid,control,min(dateofoldestscheditem) DOOSI from dms.dbo.glschedule where currentmonth > DATEADD(dd,-75,getdate()) and right(accountnumber,4) in ('2320','2300','2340','2341','2342') group by companyid,control )  , companyidLkp as  (SELECT distinct   [CompanyID]   ,[WebV_ID]   FROM [BI_WorkDB].[dbo].[vw_ADP_CoID_WebV_Link])    SELECT     d.AccountingName, d.Region, vi.stk_nbr, vi.mod_yr2, vi.make_desc2, vi.mod_desc2, vi.extr_color_desc2, vi.intr_color_desc2, vi.cur_odo_rd_nbr,                        vi.srs_desc2, DATEDIFF(d, e.DOOSI, GETDATE()) AS DaysInStock, vi.dflt_slng_price_amt, vi.tot_list_amt,                        vi.dflt_slng_price_amt - vi.acctg_cost_amt AS Margin, vi.tot_cost_amt AS [Invoice Price]  , CASE WHEN datediff(d, e.DOOSI, getdate()) > 365 THEN '366+ Days'  WHEN datediff(d, e.DOOSI, getdate()) > 250 THEN '251-365 Days'  WHEN datediff(d, e.DOOSI, getdate()) > 180 THEN '181-250 Days'  WHEN datediff(d, e.DOOSI, getdate()) > 120 THEN '121-180 Days'  WHEN datediff(d, e.DOOSI, getdate()) > 60 THEN '61-120 Days'  ELSE '0-60 Days' END AS AgingBucket,  CASE  WHEN datediff(d, e.DOOSI, getdate()) > 365 THEN 1  WHEN datediff(d, e.DOOSI, getdate()) > 250 THEN 2  WHEN datediff(d, e.DOOSI, getdate()) > 180 THEN 3  WHEN datediff(d, e.DOOSI, getdate()) > 120 THEN 4  WHEN datediff(d, e.DOOSI, getdate()) >  60 THEN 5 ELSE 6 END AS AgingBucketSrt,   vi.elt_inv_acct FROM         [206.22.183.247].SonicWebV_veh.dbo.veh_inventory AS vi (nolock) INNER JOIN                       vw_ADP_CoID_WebV_Link_wv AS d ON d.WebV_ID = vi.loc_id  inner join companyidLkp c on c.webv_id =d.webv_id                        inner join EntryDate e on vi.stk_nbr = e.control and e.companyid = c.companyid  WHERE     (vi.inv_stat_cd = 'INS') AND (vi.del_flg = 0) AND (vi.new_veh_flg = 1) AND (acctg_cost_amt > 1000) AND (RIGHT(vi.elt_inv_acct, 4) NOT IN ('2600',                        '2605'))                                               AND (d.AccountingName IN (@Dealership))  and ((d.AccountingName='Tom Williams Porsche/Audi' and left(vi.elt_inv_acct,1) in ('2','3')) or   (d.AccountingName='Tom Williams BMW/MINI' and left(vi.elt_inv_acct,1) in ('1','5')) or d.AccountingName not in ('Tom Williams Porsche/Audi','Tom Williams BMW/MINI','Porsche Audi West Houston'))   and not   (d.AccountingName='Global Imports' and make_desc2 ='MINI')  and not   (d.AccountingName='Global MINI' and make_desc2 = 'BMW')   ORDER BY vi.make_desc2, stk_nbr, vin2, d.AccountingName, last_chng_dttm DESC                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     
/BI - New Vehicles/New Inventory - Count By Make                                                                                                                                                                                                                                                                                                                                                                                         |New Inventory - Count By Make                                                                                                                                                                                                                                                                                                                                                                                                            |DistList                                                                                                                                                                                                                                                       |Text                                                                                                |SELECT     r.EMailAddress, r.Role, r.RVPEmailAddress,                        r.RCtrlEmailAddress, nid.WebVID, nid.Region,                        nid.Store, nid.ADPID, 'New Inventory - ' + ' ' + nid.store as Subject FROM         tblRecipients r INNER JOIN vw_NewInvDist nid ON r.DMSCompanyID = nid.adpid where r.Role = 'GM'                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              
/BI - New Vehicles/New Inventory - Count By Make                                                                                                                                                                                                                                                                                                                                                                                         |New Inventory - Count By Make                                                                                                                                                                                                                                                                                                                                                                                                            |NewInventory                                                                                                                                                                                                                                                   |Text                                                                                                |with EntryDate as (select companyid,control,min(dateofoldestscheditem) DOOSI from dms.dbo.glschedule where currentmonth > DATEADD(dd,-75,getdate()) and right(accountnumber,4) in ('2320','2300','2340','2341','2342') group by companyid,control )  , companyidLkp as  (SELECT distinct   [CompanyID]   ,[WebV_ID]   FROM [BI_WorkDB].[dbo].[vw_ADP_CoID_WebV_Link])  SELECT     d.AccountingName, d.Region, vi.stk_nbr, vi.mod_yr2,   case when vi.make_desc2 like '%mercedes%' then 'Mercedes Benz' else vi.make_desc2 end make_desc2   , vi.mod_desc2, vi.extr_color_desc2, vi.intr_color_desc2, vi.cur_odo_rd_nbr,                        vi.srs_desc2, DATEDIFF(d, e.DOOSI, GETDATE()) AS DaysInStock, vi.dflt_slng_price_amt, vi.tot_list_amt,                        vi.dflt_slng_price_amt - vi.acctg_cost_amt AS Margin,         CASE WHEN datediff(d, e.DOOSI, getdate()) > 365 THEN '366+ Days'         WHEN datediff(d, e.DOOSI, getdate()) > 275 THEN '276-365 Days'         WHEN datediff(d, e.DOOSI, getdate()) > 180 THEN '181-275 Days'         WHEN datediff(d, e.DOOSI, getdate()) > 90 THEN '91-180 Days'         ELSE '0-90 Days' END AS AgingBucket,  CASE WHEN datediff(d, e.DOOSI, getdate()) > 365 THEN 1 WHEN datediff(d,                        e.DOOSI, getdate()) > 275 THEN 2 WHEN datediff(d, e.DOOSI, getdate()) > 180 THEN 3 WHEN datediff(d, e.DOOSI, getdate())                        > 90 THEN 4 ELSE 5 END AS AgingBucketSrt, RIGHT(vi.elt_inv_acct, 4) AS AcctNo FROM         [206.22.183.247].SonicWebV_veh.dbo.veh_inventory AS vi (nolock) INNER JOIN                       vw_ADP_CoID_WebV_Link_wv AS d ON d.WebV_ID = vi.loc_id  inner join companyidLkp c on c.webv_id =d.webv_id                       inner join EntryDate e on vi.stk_nbr = e.control and e.companyid = c.companyid WHERE     (vi.inv_stat_cd = 'INS') AND (vi.del_flg = 0) AND (vi.new_veh_flg = 1) AND (acctg_cost_amt > 1000) AND (vi.loc_id IN (@Stores)) AND                        (NOT (RIGHT(vi.elt_inv_acct, 4) IN ('2605', '2600')))and ((d.AccountingName='Tom Williams Porsche/Audi' and left(vi.elt_inv_acct,1) in ('2','3')) or   (d.AccountingName='Tom Williams BMW/MINI' and left(vi.elt_inv_acct,1) in ('1','5')) or   (d.AccountingName='BMW of Ann Arbor' and left(vi.elt_inv_acct,1) in ('1')) or   (d.AccountingName='Mercedes of Ann Arbor' and left(vi.elt_inv_acct,1) in ('2'))  or d.AccountingName not in ('Tom Williams Porsche/Audi'    ,'Tom Williams BMW/MINI'    ,'BMW of Ann Arbor'    ,'Mercedes of Ann Arbor' ,'Porsche Audi West Houston'))   and not   (d.AccountingName='Global Imports' and make_desc2 ='MINI')  and not   (d.AccountingName='Global MINI' and make_desc2 = 'BMW')   and not   (d.AccountingName='BMW & Mini of Nashville' and make_desc2 ='MINI')  and not   (d.AccountingName='BMW MINI of Nashville' and make_desc2 = 'BMW')   --and vin2 = '3FA6P0H75DR102655' ORDER BY vi.make_desc2, stk_nbr, vin2, d.AccountingName, last_chng_dttm DESC                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        
/BI - New Vehicles/New Inventory - Count By Make                                                                                                                                                                                                                                                                                                                                                                                         |New Inventory - Count By Make                                                                                                                                                                                                                                                                                                                                                                                                            |Regions                                                                                                                                                                                                                                                        |Text                                                                                                |SELECT DISTINCT Region FROM         vw_ADP_CoID_WebV_Link                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       
/BI - New Vehicles/New Inventory - Count By Make                                                                                                                                                                                                                                                                                                                                                                                         |New Inventory - Count By Make                                                                                                                                                                                                                                                                                                                                                                                                            |StoresAvailable                                                                                                                                                                                                                                                |Text                                                                                                |SELECT DISTINCT AccountingName, WebV_ID FROM            vw_ADP_CoID_WebV_Link_wv WHERE        (Region IN (@Regions)) ORDER BY AccountingName                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
/BI - New Vehicles/New Inventory - Playbook - All_exp                                                                                                                                                                                                                                                                                                                                                                                    |New Inventory - Playbook - All_exp                                                                                                                                                                                                                                                                                                                                                                                                       |DistList                                                                                                                                                                                                                                                       |Text                                                                                                |SELECT     r.EMailAddress, r.Role, r.RVPEmailAddress,                        r.RCtrlEmailAddress, nid.WebVID, nid.Region,                        nid.Store, nid.ADPID, 'New Inventory - ' + ' ' + nid.store as Subject FROM         tblRecipients r INNER JOIN vw_NewInvDist nid ON r.DMSCompanyID = nid.adpid where r.Role = 'GM'                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              
/BI - New Vehicles/New Inventory - Playbook - All_exp                                                                                                                                                                                                                                                                                                                                                                                    |New Inventory - Playbook - All_exp                                                                                                                                                                                                                                                                                                                                                                                                       |NewInventory                                                                                                                                                                                                                                                   |Text                                                                                                |with EntryDate as (select companyid,control,min(dateofoldestscheditem) DOOSI from dms.dbo.glschedule where currentmonth > DATEADD(dd,-550,getdate()) and right(accountnumber,4) in ('2320','2300','2340','2341','2342') group by companyid,control )  , companyidLkp as  (SELECT distinct   [CompanyID]   ,[WebV_ID]   FROM [BI_WorkDB].[dbo].[vw_ADP_CoID_WebV_Link])  SELECT     d.AccountingName, d.Region, vi.stk_nbr, vi.mod_yr2, vi.make_desc2, vi.mod_desc2, vi.extr_color_desc2, vi.intr_color_desc2, vi.cur_odo_rd_nbr,                        vi.srs_desc2, DATEDIFF(d, e.DOOSI, GETDATE()) AS DaysInStock, vi.dflt_slng_price_amt, vi.tot_list_amt,                        vi.dflt_slng_price_amt - vi.acctg_cost_amt AS Margin,    CASE WHEN datediff(d, e.DOOSI, getdate()) > 365 THEN '366+ Days'  --WHEN datediff(d, e.DOOSI, getdate()) > 250 THEN '251-365 Days'  WHEN datediff(d, e.DOOSI, getdate()) > 275 THEN '276-365 Days'  WHEN datediff(d, e.DOOSI, getdate()) > 180 THEN '181-275 Days'  WHEN datediff(d, e.DOOSI, getdate()) > 90 THEN '91-180 Days'  ELSE '0-90 Days' END AS AgingBucket,  CASE  WHEN datediff(d, e.DOOSI, getdate()) > 365 THEN 1  --WHEN datediff(d, e.DOOSI, getdate()) > 250 THEN 2  WHEN datediff(d, e.DOOSI, getdate()) > 275 THEN 2  WHEN datediff(d, e.DOOSI, getdate()) > 180 THEN 3  WHEN datediff(d, e.DOOSI, getdate()) >  90 THEN 4 ELSE 5 END AS AgingBucketSrt,   RIGHT(vi.elt_inv_acct, 4) AS AcctNo FROM         [206.22.183.247].SonicWebV_veh.dbo.veh_inventory AS vi (nolock) INNER JOIN                       vw_ADP_CoID_WebV_Link_wv AS d ON d.WebV_ID = vi.loc_id  inner join companyidLkp c on c.webv_id =d.webv_id                       inner join EntryDate e on vi.stk_nbr = e.control and e.companyid = c.companyid WHERE     (vi.inv_stat_cd = 'INS') AND (vi.del_flg = 0) AND (vi.new_veh_flg = 1) AND (acctg_cost_amt > 1000) AND (vi.loc_id IN (@Stores)) AND                        (NOT (RIGHT(vi.elt_inv_acct, 4) IN ('2605', '2600')))and ((d.AccountingName='Tom Williams Porsche/Audi' and left(vi.elt_inv_acct,1) in ('2','3')) --or   (d.AccountingName='Tom Williams BMW/MINI' and left(vi.elt_inv_acct,1) in ('1','5')) or   (d.AccountingName='BMW of Ann Arbor' and left(vi.elt_inv_acct,1) in ('1')) or   (d.AccountingName='Mercedes of Ann Arbor' and left(vi.elt_inv_acct,1) in ('2'))  or d.AccountingName not in ('Tom Williams Porsche/Audi'    --,'Tom Williams BMW/MINI'    ,'BMW of Ann Arbor'    ,'Mercedes of Ann Arbor' ,'Porsche Audi West Houston'))   and not   (d.AccountingName='Global Imports' and make_desc2 ='MINI')  and not   (d.AccountingName='Global MINI' and make_desc2 = 'BMW')   and not   (d.AccountingName='BMW & Mini of Nashville' and make_desc2 ='MINI')  and not   (d.AccountingName='BMW MINI of Nashville' and make_desc2 = 'BMW') -- and not   (d.AccountingName='Tom Williams Mini' and make_desc2 = 'BMW') -- and not   (d.AccountingName='Tom Williams BMW' and make_desc2 = 'Mini')   and not   (d.AccountingName='Jaguar of South Atlanta' and make_desc2 = 'Land Rover')  and not   (d.AccountingName='Land Rover of South Atlanta' and make_desc2 = 'Jaguar')         and not   (d.AccountingName='Land Rover Birmingham' and Region = 'BMW/Mini') --and vin2 = '3FA6P0H75DR102655' ORDER BY vi.make_desc2, stk_nbr, vin2, d.AccountingName, last_chng_dttm DESC                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      
