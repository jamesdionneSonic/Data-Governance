   ========================================================= */

:root {
  --bg: #f4f7fb;
  --surface: #ffffff;
  --surface-muted: #f0f5ff;
  --surface-hover: #e8f0ff;
  --text: #0f172a;
  --text-muted: #64748b;
  --text-faint: #94a3b8;
  --primary: #2563eb;
  --primary-light: #dbeafe;
  --primary-strong: #1d4ed8;
  --accent: #0ea5e9;
  --border: #e2e8f0;
  --border-strong: #cbd5e1;
  --success: #16a34a;
  --success-bg: #dcfce7;
  --warning: #d97706;
  --warning-bg: #fef9c3;
  --danger: #dc2626;
  --danger-bg: #fee2e2;
  --purple: #7c3aed;
  --orange: #ea580c;
  --teal: #0d9488;
  --radius: 12px;
  --radius-sm: 8px;
  --radius-lg: 16px;
  --shadow-sm: 0 1px 3px rgba(15,23,42,0.07),0 1px 2px rgba(15,23,42,0.04);
  --shadow: 0 4px 16px rgba(15,23,42,0.08),0 1px 4px rgba(15,23,42,0.04);
  --shadow-lg: 0 12px 32px rgba(15,23,42,0.12),0 4px 8px rgba(15,23,42,0.06);
  --sidebar-width: 216px;
}

* { box-sizing: border-box; }

html, body {
  margin: 0;
  padding: 0;
  width: 100%;
  height: 100%;
}

body {
  font-family: Inter,"Segoe UI",Roboto,Arial,sans-serif;
  font-size: 14px;
  line-height: 1.5;
  color: var(--text);
  background: var(--bg);
  -webkit-font-smoothing: antialiased;
  -webkit-tap-highlight-color: transparent;
  -moz-user-select: none;
  -webkit-user-select: none;
  user-select: none;
  overflow-x: hidden;
}

/* LOGIN */
.login-page {
  min-height: 100vh;
  display: grid;
  place-items: center;
  background: linear-gradient(135deg,#0f172a 0%,#1e3a8a 50%,#0f172a 100%);
  padding: 24px;
}

.login-card {
  width: min(480px,100%);
  background: rgba(255,255,255,0.97);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  padding: 40px 36px;
  text-align: center;
}

.login-card h1 { margin: 0 0 6px; font-size: 24px; font-weight: 700; }
.subtitle { color: var(--text-muted); margin-bottom: 28px; font-size: 14px; }
.login-grid { display: grid; gap: 10px; }
.dev-hint { margin-top: 16px; color: var(--text-faint); font-size: 12px; }

/* APP SHELL */
.app-shell { 
  min-height: 100vh; 
  width: 100%;
  max-width: 100%;
  overflow: hidden;
}
.app-shell.sidebar-collapsed { }

/* SIDEBAR */
.sidebar {
  color: #cbd5e1;
  overflow: hidden;
}

.sidebar .v-navigation-drawer__content {
  display: flex;
  flex-direction: column;
}

.brand {
  padding: 14px 12px 12px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  display: flex; align-items: center; gap: 10px;
  flex-shrink: 0;
}

.brand-icon {
  width: 34px; height: 34px;
  background: linear-gradient(135deg,#2563eb,#0ea5e9);
  border-radius: 9px;
  display: grid; place-items: center;
  font-size: 17px; flex-shrink: 0;
}

.brand h2 { margin: 0; font-size: 14px; font-weight: 700; color: #fff; line-height: 1.2; }
.brand p  { margin: 1px 0 0; color: #94a3b8; font-size: 10px; }

.nav-list { padding: 8px 8px; display: grid; gap: 10px; flex: 1; overflow-y: auto; }

.nav-section {
  display: grid;
  gap: 1px;
}

.nav-section-label {
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #94a3b8;
  padding: 4px 9px 5px;
}

.nav-btn {
  background: transparent; color: #94a3b8;
  border: 0; text-align: left;
  padding: 7px 9px; border-radius: 8px;
  cursor: pointer;
  display: flex; align-items: center; gap: 9px;
  transition: background 0.12s,color 0.12s;
  font-size: 12px; font-weight: 500;
}

.nav-btn:hover  { background: rgba(255,255,255,0.06); color: #e2e8f0; }
.nav-btn.active { background: rgba(37,99,235,0.22); color: #93c5fd; font-weight: 600; }

.nav-icon { font-size: 15px; width: 20px; text-align: center; flex-shrink: 0; }

.app-shell.sidebar-collapsed .brand { justify-content: center; padding: 12px 8px; }
.app-shell.sidebar-collapsed .nav-btn { justify-content: center; padding: 8px 6px; }
.app-shell.sidebar-collapsed .nav-icon { width: auto; }
.app-shell.sidebar-collapsed .nav-list { gap: 1px; }

.sidebar-footer {
  padding: 10px 14px;
  border-top: 1px solid rgba(255,255,255,0.05);
  font-size: 10px; color: #94a3b8; flex-shrink: 0;
}

.sidebar-overlay {
  display: none;
}

/* MAIN */
.main { 
  min-width: 0; 
  min-height: 100vh;
  width: 100%;
  max-width: 100%;
}

/* TOPBAR */
.topbar {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 10px 20px;
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
  gap: 14px;
  position: sticky; 
  top: 0; 
  z-index: 100;
  width: 100%;
  min-height: 44px;
  flex-wrap: wrap;
}

.topbar-left h4 { margin: 0 0 1px; font-size: 14px; font-weight: 600; }
.user-meta { color: var(--text-muted); font-size: 11px; }
.topbar-nav-controls { display: inline-flex; gap: 6px; margin-bottom: 4px; }

.workflow-inline { display: flex; align-items: center; gap: 8px; margin-top: 3px; }
.workflow-inline-label {
  font-size: 11px; color: var(--primary); font-weight: 700;
  background: var(--primary-light); padding: 1px 7px; border-radius: 999px;
}
.workflow-inline-next { font-size: 11px; color: var(--text-muted); }

.profile-trigger {
  padding: 0;
  min-width: 36px;
}

.profile-avatar {
  background: linear-gradient(135deg,#2563eb,#0ea5e9);
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  border: 2px solid rgba(255,255,255,0.9);
  box-shadow: var(--shadow-sm);
}

.profile-menu-card {
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 12px;
  display: grid;
  gap: 10px;
}

.profile-menu-header {
  display: flex;
  align-items: center;
  gap: 10px;
}

.profile-identity {
  display: grid;
  min-width: 0;
}

.profile-identity strong {
  font-size: 13px;
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-identity span {
  font-size: 11px;
  color: var(--text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-role-row {
  display: flex;
  gap: 5px;
  flex-wrap: wrap;
}

.profile-section {
  border: 1px solid var(--border);
  background: var(--surface-muted);
  border-radius: var(--radius-sm);
  padding: 9px;
}

.profile-section h5 {
  margin: 0 0 7px;
  font-size: 11px;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.profile-info-grid {
  display: grid;
  gap: 6px;
}

.profile-info-item {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  font-size: 11px;
}

.profile-info-item span {
  color: var(--text-muted);
  flex-shrink: 0;
}

.profile-info-item strong {
  color: var(--text);
  font-weight: 600;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-token-block {
  display: grid;
  gap: 4px;
  margin-top: 6px;
}

.profile-token-block span {
  font-size: 10px;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.profile-token-block code {
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  font-size: 11px;
  padding: 7px 8px;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: var(--surface);
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.profile-footer {
  display: flex;
  justify-content: flex-end;
  gap: 7px;
  flex-wrap: wrap;
}

/* CONTENT */
.content { 
  padding: 18px; 
  overflow: auto; 
  width: 100%;
  max-width: 100%;
  min-height: calc(100vh - 60px);
}

/* GRID */
.grid { 
  display: grid; 
  grid-template-columns: repeat(12,minmax(0,1fr)); 
  gap: 14px;
  width: 100%;
  max-width: 100%;
}

/* CARD */
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
  padding: 16px;
  transition: box-shadow 0.15s;
}
.card:hover { box-shadow: var(--shadow); }
.card h3 { margin: 0 0 12px; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); }
.card h4 { margin: 12px 0 8px; font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em; }

/* KPI */
.kpi { grid-column: span 3; display: flex; flex-direction: column; gap: 4px; }
.kpi .value {
  font-size: 30px; font-weight: 800; line-height: 1;
  background: linear-gradient(135deg,#1d4ed8,#0ea5e9);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.kpi .label { color: var(--text-muted); font-size: 12px; font-weight: 500; }

/* SPANS */
.span-12 { grid-column: span 12; }
.span-9  { grid-column: span 9; }
.span-8  { grid-column: span 8; }
.span-7  { grid-column: span 7; }
.span-6  { grid-column: span 6; }
.span-5  { grid-column: span 5; }
.span-4  { grid-column: span 4; }
.span-3  { grid-column: span 3; }

/* RESPONSIVE DESIGN — Large screens (1920px+) */
@media (min-width:1920px) {
  .card { padding: 18px; }
  .content { padding: 20px; }
  .kpi .value { font-size: 36px; }
}

/* RESPONSIVE DESIGN — Desktop (1200px–1919px) */
@media (max-width:1919px) {
  .kpi { grid-column: span 3; }
  .span-8, .span-9 { grid-column: span 8; }
  .span-7 { grid-column: span 7; }
}

@media (max-width:1400px) {
  :root { --sidebar-width: 216px; }
  .kpi { grid-column: span 4; }
  .span-8, .span-9 { grid-column: span 12; }
  .span-7 { grid-column: span 12; }
  .span-6 { grid-column: span 6; }
}

/* RESPONSIVE DESIGN — Tablet landscape (1024px–1399px) */
@media (max-width:1399px) {
  :root { --sidebar-width: 216px; }
  .card { padding: 14px; }
  .content { padding: 14px; }
  .kpi { grid-column: span 6; }
  .span-12 { grid-column: span 12; }
  .span-9, .span-8, .span-7 { grid-column: span 12; }
  .span-6, .span-5 { grid-column: span 6; }
  .span-4, .span-3 { grid-column: span 6; }
  .search-hero { padding: 20px 18px; }
  .search-hero h2 { font-size: 18px; }
  .kpi .value { font-size: 26px; }
}

/* RESPONSIVE DESIGN — Small tablet (768px–1023px) */
@media (max-width:1023px) {
  :root { 
    --sidebar-width: 0px; 
    --radius: 10px;
    --radius-sm: 6px;
  }
  .topbar { padding: 8px 14px; flex-wrap: wrap; }
  .topbar-left h4 { font-size: 13px; }
  .user-meta { font-size: 10px; }
  .workflow-inline { font-size: 11px; }
  
  .content { padding: 12px; }
  .card { padding: 12px; }
  .card h3 { margin-bottom: 8px; font-size: 12px; }
  .card h4 { margin-top: 10px; font-size: 11px; }
  
  .search-hero { padding: 16px 12px; margin-bottom: 12px; }
  .search-hero h2 { font-size: 16px; margin-bottom: 2px; }
  .search-hero p { font-size: 12px; margin-bottom: 12px; }
  
  .kpi { grid-column: span 6; }
  .kpi .value { font-size: 24px; }
  .kpi .label { font-size: 11px; }
  
  .span-12 { grid-column: span 12; }
  .span-9, .span-8, .span-7, .span-6, .span-5 { grid-column: span 12; }
  .span-4, .span-3 { grid-column: span 12; }
  
  .browse-layout { grid-template-columns: 1fr; }
  .facet-rail { position: relative; top: auto; margin-bottom: 12px; }
  
  .grid { gap: 12px; }
  .asset-card { grid-template-columns: 30px 1fr auto; gap: 8px; padding: 10px 12px; }
  .asset-type-icon { width: 30px; height: 30px; font-size: 12px; }
  .asset-description { font-size: 11px; }
  .asset-meta { font-size: 10px; flex-wrap: wrap; gap: 4px; }
  
  .detail-panel { margin-top: 12px; }
  .stat-row { gap: 12px; padding: 8px 0; }
  .stat-value { font-size: 16px; }
  .stat-label { font-size: 10px; }
  
  .mini-stack { gap: 6px; }
  .mini-metric { padding: 6px 10px; font-size: 11px; }
  
  .badge { padding: 1px 6px; font-size: 10px; }
  .btn-row { gap: 6px; }
}

/* RESPONSIVE DESIGN — Mobile landscape (481px–767px) */
@media (max-width:768px) {
  :root { --sidebar-width: 0px; }
  
  .topbar { padding: 6px 10px; gap: 8px; }
  .topbar-left h4 { font-size: 13px; margin-bottom: 0; }
  .user-meta { display: none; }
  .workflow-inline { display: none; }
  
  .content { padding: 10px; }
  .card { padding: 10px; }
  .card h3 { font-size: 11px; margin-bottom: 6px; }
  .card h4 { font-size: 10px; margin-top: 8px; }
  
  .grid { gap: 10px; }
  .kpi { grid-column: span 12; }
  .kpi .value { font-size: 22px; }
  
  .search-hero { padding: 12px 10px; margin-bottom: 10px; border-radius: var(--radius-sm); }
  .search-hero h2 { font-size: 15px; margin-bottom: 1px; }
  .search-hero p { font-size: 11px; margin-bottom: 10px; }
  .search-bar-wrap { flex-direction: column; gap: 6px; }
  .search-bar-wrap input { font-size: 14px; } /* Prevent zoom on iOS */
  .search-hint { font-size: 10px; }
  
  .asset-card { grid-template-columns: 28px 1fr; gap: 6px; padding: 8px 10px; }
  .asset-type-icon { width: 28px; height: 28px; font-size: 11px; }
  .asset-body { min-width: 0; }
  .asset-name { font-size: 12px; margin-bottom: 1px; }
  .asset-description { font-size: 10px; margin-bottom: 4px; }
  .asset-meta { gap: 3px; font-size: 9px; }
  .asset-actions { display: none; }
  
  .detail-panel { border-radius: var(--radius-sm); }
  .detail-header { padding: 10px 12px 8px; }
  .detail-name { font-size: 13px; }
  .detail-path { font-size: 10px; }
  .detail-body { padding: 10px 12px; }
  
  .stat-row { gap: 8px; padding: 6px 0; flex-wrap: wrap; }
  .stat-item { min-width: 60px; }
  .stat-value { font-size: 14px; }
  .stat-label { font-size: 9px; }
  
  .tab-row { gap: 6px; margin-bottom: 8px; }
  .mini-stack { gap: 5px; }
  .mini-metric { padding: 5px 8px; font-size: 10px; }
  .mini-metric strong { font-size: 12px; }
  
  .form-row { gap: 8px; grid-template-columns: 1fr; }
  .col-2, .col-3, .col-4, .col-5, .col-6, .col-7, .col-8, .col-9, .col-10, .col-12 { grid-column: span 1; }
  
  label { font-size: 10px; margin-bottom: 3px; }
  .btn-row { gap: 4px; font-size: 12px; }
  .badge { padding: 1px 5px; font-size: 9px; }

  .profile-menu-card {
    min-width: min(92vw, 360px);
  }

  .profile-info-item {
    flex-direction: column;
    align-items: flex-start;
    gap: 1px;
  }

  .profile-info-item strong {
    text-align: left;
    white-space: normal;
  }
  
  table { min-width: 100%; font-size: 11px; }
  th, td { padding: 6px 8px; }
  
  .graph-box { min-height: 320px; }
  #cy-graph { height: 320px; }
  
  .persona-kpi-grid { grid-template-columns: 1fr 1fr; gap: 8px; }
  .export-cards { grid-template-columns: repeat(auto-fill,minmax(130px,1fr)); gap: 8px; }
  .pack-cards { grid-template-columns: 1fr; gap: 8px; }
  .health-grid { grid-template-columns: repeat(auto-fill,minmax(150px,1fr)); gap: 8px; }
}

/* RESPONSIVE DESIGN — Mobile portrait (up to 480px) */
@media (max-width:480px) {
  :root {
    --sidebar-width: 0px;
    --radius: 8px;
    --radius-sm: 6px;
    --radius-lg: 12px;
  }
  
  * { box-sizing: border-box; }
  
  body { font-size: 13px; }
  label { font-size: 10px; }
  
  .topbar { 
    padding: 6px 8px; 
    gap: 6px; 
    min-height: 44px;
    flex-wrap: wrap;
    row-gap: 2px;
  }
  
  .topbar-left { width: 100%; }
  .topbar-left h4 { font-size: 12px; margin: 0; font-weight: 600; }
  .user-meta { display: none; }
  .workflow-inline { display: none; }
  
  .topbar-nav-controls { gap: 4px; }
  .btn-row { 
    gap: 4px; 
    width: 100%;
    flex-wrap: wrap;
  }
  .btn-row > * { min-width: auto; font-size: 11px; padding: 4px 8px; }
  
  .content { 
    padding: 8px;
    min-height: calc(100vh - 60px);
  }
  
  .grid { 
    gap: 8px; 
    grid-template-columns: 1fr;
  }
  
  .card { 
    padding: 8px;
    border-radius: var(--radius-sm);
  }
  .card h3 { 
    font-size: 10px; 
    margin: 0 0 6px;
    letter-spacing: 0.06em;
  }
  .card h4 { 
    font-size: 10px; 
    margin: 6px 0 4px;
  }
  
  .search-hero { 
    padding: 10px 8px;
    margin-bottom: 8px;
    border-radius: var(--radius-sm);
  }
  .search-hero h2 { 
    font-size: 14px; 
    margin: 0 0 1px;
    font-weight: 700;
  }
  .search-hero p { 
    font-size: 10px; 
    margin: 0 0 8px;
    color: #93c5fd;
  }
  .search-bar-wrap { 
    flex-direction: column; 
    gap: 5px;
    max-width: 100%;
  }
  .search-bar-wrap input { font-size: 14px; } /* iOS zoom prevention */
  .search-hint { 
    font-size: 9px; 
    margin-top: 4px;
  }
  
  .kpi { 
    grid-column: span 1;
    gap: 2px;
  }
  .kpi .value { 
    font-size: 18px; 
    line-height: 1.1;
  }
  .kpi .label { 
    font-size: 10px; 
    font-weight: 400;
  }
  
  .browse-layout { 
    grid-template-columns: 1fr;
    gap: 8px;
  }
  
  .facet-rail {
    position: relative;
    top: auto;
    sticky: initial;
  }
  .facet-rail-title { font-size: 9px; }
  .facet-group { margin-bottom: 10px; }
  .facet-group-title { font-size: 10px; margin-bottom: 4px; }
  .facet-item { font-size: 11px; padding: 2px 0; }
  
  .asset-results { gap: 6px; }
  .asset-card { 
    grid-template-columns: 24px 1fr; 
    gap: 5px; 
    padding: 6px 8px;
    border-radius: var(--radius-sm);
  }
  .asset-type-icon { 
    width: 24px; 
    height: 24px; 
    font-size: 10px;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .asset-name { 
    font-size: 11px; 
    font-weight: 600;
    margin-bottom: 1px;
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }
  .asset-description { 
    font-size: 10px; 
    color: var(--text-muted);
    -webkit-line-clamp: 2;
    margin-bottom: 2px;
  }
  .asset-meta { 
    gap: 2px; 
    font-size: 8px;
    margin-top: 2px;
  }
  .asset-actions { display: none; }
  
  .detail-panel { 
    margin-top: 8px;
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-sm);
  }
  .detail-header { 
    padding: 8px 10px 6px;
    display: flex;
    gap: 8px;
    align-items: flex-start;
  }
  .detail-name { 
    font-size: 12px; 
    font-weight: 700;
    margin: 0 0 1px;
  }
  .detail-path { 
    font-size: 9px; 
    font-family: monospace;
  }
  .detail-body { 
    padding: 8px 10px;
  }
  
  .tab-row { 
    gap: 4px; 
    margin-bottom: 6px;
    padding-bottom: 4px;
  }
  
  .stat-row { 
    gap: 6px; 
    padding: 5px 0;
    flex-wrap: wrap;
    border-bottom: none;
  }
  .stat-item { 
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 50px;
  }
  .stat-value { 
    font-size: 13px; 
    font-weight: 700;
    line-height: 1.1;
  }
  .stat-label { 
    font-size: 8px; 
    font-weight: 400;
  }
  
  .form-row { 
    gap: 6px;
    grid-template-columns: 1fr;
  }
  .col-2, .col-3, .col-4, .col-5, .col-6, .col-7, .col-8, .col-9, .col-10, .col-12 {
    grid-column: span 1;
  }
  
  .mini-stack { gap: 4px; }
  .mini-metric { 
    padding: 4px 7px; 
    font-size: 9px;
    gap: 6px;
  }
  .mini-metric span { font-size: 8px; }
  .mini-metric strong { font-size: 11px; }
  
  .ranked-list { gap: 4px; }
  .ranked-item { 
    grid-template-columns: 20px 1fr auto; 
    gap: 5px;
    padding: 6px 8px;
    font-size: 10px;
  }
  .ranked-num { font-size: 9px; }
  .ranked-score { font-size: 11px; }
  
  .badge { 
    padding: 1px 4px; 
    font-size: 8px;
    gap: 2px;
  }
  
  table { min-width: 100%; }
  th { padding: 5px 6px; font-size: 9px; }
  td { padding: 5px 6px; font-size: 10px; }
  
  .graph-box { 
    min-height: 240px;
    border-radius: var(--radius-sm);
  }
  #cy-graph { height: 240px; }
  #mermaid-graph { padding: 8px; }
  
  .graph-legend { 
    font-size: 9px; 
    gap: 8px;
    flex-wrap: wrap;
    padding: 6px 8px;
    margin-top: 6px;
  }
  
  .persona-kpi-grid { 
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    margin-top: 6px;
  }
  
  .export-cards { 
    grid-template-columns: repeat(auto-fill, minmax(100px,1fr));
    gap: 6px;
  }
  .export-icon { font-size: 22px; margin-bottom: 4px; }
  .export-label { font-size: 10px; }
  .export-desc { font-size: 9px; }
  
  .pack-cards { grid-template-columns: 1fr; gap: 6px; }
  .pack-card { padding: 10px; }
  .pack-card-header { font-size: 12px; margin-bottom: 3px; }
  .pack-files { font-size: 10px; }
  
  .health-grid { 
    grid-template-columns: repeat(auto-fill, minmax(120px,1fr));
    gap: 6px;
  }
  .health-card { 
    padding: 8px 10px;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }
  .health-icon { font-size: 16px; }
  .health-name { font-size: 11px; }
  .health-desc { font-size: 9px; }
  
  .empty-state { 
    padding: 24px 16px;
    text-align: center;
  }
  .empty-state-icon { font-size: 36px; margin-bottom: 8px; }
  .empty-state h4 { 
    font-size: 12px;
    margin: 0 0 4px;
  }
  .empty-state p { 
    font-size: 10px;
    max-width: 100%;
    margin: 0 0 8px;
  }
  
  .section-header { 
    gap: 8px;
    margin-bottom: 8px;
  }
  .section-title { 
    font-size: 11px;
    font-weight: 700;
  }
  
  .toast { 
    bottom: 12px; 
    right: 12px;
    left: 12px;
    max-width: none;
    font-size: 11px;
    padding: 8px 12px;
  }
}

@media (max-width:400px) {
  .topbar-left h4 { font-size: 11px; }
  .card h3 { font-size: 9px; }
  .kpi .value { font-size: 16px; }
  .asset-name { font-size: 10px; }
}

/* SEARCH HERO */
.search-hero {
  background: linear-gradient(135deg,#0f172a 0%,#1e3a8a 60%,#1d4ed8 100%);
  border-radius: var(--radius);
  padding: 28px 24px 24px;
  text-align: center;
}

.search-hero h2 { margin: 0 0 4px; font-size: 20px; font-weight: 700; color: #fff; }
.search-hero p  { margin: 0 0 16px; color: #93c5fd; font-size: 13px; }

.search-bar-wrap {
  display: flex; gap: 8px;
  max-width: 640px; margin: 0 auto;
}

.search-hint { margin-top: 8px; font-size: 11px; color: #60a5fa; }

/* BROWSE LAYOUT */
.browse-layout { display: grid; grid-template-columns: 210px 1fr; gap: 14px; align-items: start; }

/* FACET RAIL */
.facet-rail {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 12px;
  position: sticky; top: 64px;
}

.facet-rail-title { font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 10px; }

.facet-group { margin-bottom: 14px; }
.facet-group-title { font-size: 11px; font-weight: 600; color: var(--text); margin-bottom: 5px; cursor: pointer; }
.facet-item { display: flex; align-items: center; gap: 7px; padding: 3px 0; cursor: pointer; font-size: 12px; color: var(--text-muted); }
.facet-item:hover { color: var(--primary); }
.facet-item.active { color: var(--primary); font-weight: 700; }
.facet-count { margin-left: auto; font-size: 10px; background: var(--surface-muted); padding: 1px 5px; border-radius: 999px; }

/* ASSET CARDS */
.asset-results { display: grid; gap: 8px; }

.asset-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 12px 14px;
  cursor: pointer;
  display: grid; grid-template-columns: auto 1fr auto; gap: 10px; align-items: start;
  box-shadow: var(--shadow-sm);
  transition: all 0.12s;
}
.asset-card:hover { border-color: var(--primary); box-shadow: var(--shadow),0 0 0 1px var(--primary-light); transform: translateY(-1px); }
.asset-card.selected { border-color: var(--primary); background: #f0f7ff; }

.asset-type-icon {
  width: 34px; height: 34px; border-radius: 7px;
  display: grid; place-items: center;
  font-size: 13px; font-weight: 700;
  flex-shrink: 0; color: #fff;
}
.type-table   { background: #2563eb; }
.type-view    { background: #7c3aed; }
.type-proc    { background: #ea580c; }
.type-fn      { background: #0d9488; }
.type-trigger { background: #be123c; }
.type-other   { background: #64748b; }

.asset-body { min-width: 0; }
.asset-name { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 2px; display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
.asset-description { font-size: 12px; color: var(--text-muted); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 5px; }
.asset-meta { display: flex; align-items: center; gap: 5px; flex-wrap: wrap; margin-top: 3px; }
.asset-actions { display: flex; gap: 5px; align-items: center; flex-shrink: 0; }

/* BADGES */
.badge { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 999px; font-size: 11px; font-weight: 600; white-space: nowrap; }
.badge.admin     { background: #fee2e2; color: #991b1b; }
.badge.poweruser { background: #fef3c7; color: #92400e; }
.badge.analyst   { background: #dcfce7; color: #166534; }
.badge.viewer    { background: #dbeafe; color: #1e3a8a; }

.trust-verified   { background: #dcfce7; color: #166534; border: 1px solid #86efac; }
.trust-warning    { background: #fef9c3; color: #854d0e; border: 1px solid #fde047; }
.trust-deprecated { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
.trust-draft      { background: #f1f5f9; color: #64748b; border: 1px solid #cbd5e1; }

.type-chip { font-size: 10px; font-weight: 700; padding: 1px 5px; border-radius: 3px; text-transform: uppercase; letter-spacing: 0.06em; background: var(--surface-muted); color: var(--text-muted); }
.schema-badge { font-size: 11px; color: #1e40af; background: #dbeafe; padding: 2px 6px; border-radius: 4px; font-weight: 500; }
.owner-chip { font-size: 11px; color: var(--text-muted); background: var(--surface-muted); padding: 2px 7px; border-radius: 999px; }
.sens-confidential { background: #fee2e2; color: #991b1b; }
.sens-internal     { background: #fef9c3; color: #854d0e; }
.sens-public       { background: #dcfce7; color: #166534; }

.status-pill { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 600; padding: 2px 9px; border-radius: 999px; }
.status-pill::before { content:""; width:6px; height:6px; border-radius:50%; background:currentColor; opacity:0.7; }
.pill-green  { background: var(--success-bg); color: var(--success); }
.pill-yellow { background: var(--warning-bg); color: var(--warning); }
.pill-red    { background: var(--danger-bg);  color: var(--danger);  }
.pill-gray   { background: #f1f5f9; color: var(--text-muted); }
.pill-blue   { background: var(--primary-light); color: var(--primary); }

/* TABS */
.tab-row { display: flex; gap: 8px; border-bottom: 2px solid var(--border); margin-bottom: 14px; padding-bottom: 8px; }

/* DETAIL PANEL */
.detail-panel { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm); }
.detail-header { padding: 14px 16px 10px; border-bottom: 1px solid var(--border); background: var(--surface-muted); }
.detail-name { font-size: 15px; font-weight: 700; color: var(--text); margin: 0 0 3px; }
.detail-path { font-size: 11px; color: var(--text-muted); font-family: ui-monospace,monospace; }
.detail-body { padding: 14px 16px; }

/* ACTIVITY FEED */
.activity-feed { display: flex; flex-direction: column; gap: 0; }
.activity-item { display: flex; gap: 9px; padding: 9px 0; border-bottom: 1px solid var(--border); align-items: flex-start; font-size: 12px; }
.activity-item:last-child { border-bottom: none; }
.activity-dot { width: 26px; height: 26px; border-radius: 50%; display: grid; place-items: center; font-size: 11px; flex-shrink: 0; margin-top: 1px; }
.activity-dot.blue   { background: var(--primary-light); color: var(--primary); }
.activity-dot.green  { background: var(--success-bg); color: var(--success); }
.activity-dot.yellow { background: var(--warning-bg); color: var(--warning); }
.activity-body { flex: 1; min-width: 0; }
.activity-title { font-weight: 500; color: var(--text); margin-bottom: 1px; }
.activity-time { font-size: 10px; color: var(--text-faint); }

/* CHECKLIST */
.check-list { display: grid; gap: 7px; }
.check-item { display: flex; align-items: center; gap: 9px; padding: 9px 11px; border-radius: 7px; font-size: 12px; }
.check-item.pass { background: var(--success-bg); color: #14532d; }
.check-item.fail { background: var(--danger-bg);  color: #7f1d1d;  }
.check-icon { font-size: 15px; flex-shrink: 0; }
.check-label { flex: 1; font-weight: 500; }

/* SECTION HEADER */
.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.section-title { font-size: 13px; font-weight: 600; color: var(--text); margin: 0; }
.section-subtitle { font-size: 11px; color: var(--text-muted); }

/* EMPTY STATE */
.empty-state { text-align: center; padding: 40px 24px; color: var(--text-muted); }
.empty-state-icon { font-size: 44px; margin-bottom: 10px; opacity: 0.35; }
.empty-state h4 { margin: 0 0 5px; font-size: 14px; color: var(--text); }
.empty-state p { margin: 0 0 14px; font-size: 12px; max-width: 300px; margin-left: auto; margin-right: auto; }

/* FORMS */
label { display: block; margin-bottom: 4px; font-weight: 600; font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em; }

.form-row { display: grid; gap: 10px; grid-template-columns: repeat(12,minmax(0,1fr)); }
.col-2  { grid-column: span 2; }
.col-3  { grid-column: span 3; }
.col-4  { grid-column: span 4; }
.col-5  { grid-column: span 5; }
.col-6  { grid-column: span 6; }
.col-7  { grid-column: span 7; }
.col-8  { grid-column: span 8; }
.col-9  { grid-column: span 9; }
.col-10 { grid-column: span 10; }
.col-12 { grid-column: span 12; }

/* BUTTONS */
.btn-row { display: flex; gap: 7px; flex-wrap: wrap; align-items: center; }

/* TABLES */
.table-wrap { overflow: auto; border: 1px solid var(--border); border-radius: var(--radius-sm); }
table { width: 100%; border-collapse: collapse; min-width: 520px; }
thead tr { background: var(--surface-muted); }
th { padding: 9px 11px; text-align: left; font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; border-bottom: 1px solid var(--border); white-space: nowrap; }
td { padding: 9px 11px; border-bottom: 1px solid var(--border); font-size: 12px; vertical-align: top; color: var(--text); }
tbody tr:last-child td { border-bottom: none; }
tbody tr:hover { background: #fafbff; }
tr.clickable { cursor: pointer; }
tr.selected td { background: #f0f7ff; }

/* GRAPH */
.graph-box { min-height: 480px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: radial-gradient(ellipse at 60% 40%,#eef4ff 0%,#f8fbff 60%,#ffffff 100%); overflow: hidden; }
#cy-graph { width: 100%; height: 480px; }
#mermaid-graph { overflow: auto; padding: 12px; }

.graph-legend { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 8px; padding: 7px 10px; background: var(--surface-muted); border-radius: var(--radius-sm); font-size: 11px; }
.legend-item { display: flex; align-items: center; gap: 4px; color: var(--text-muted); }
.legend-dot { width: 9px; height: 9px; border-radius: 2px; }

/* MINI METRICS */
.mini-stack { display: grid; gap: 7px; }
.mini-metric { border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 8px 11px; background: var(--surface-muted); display: flex; justify-content: space-between; align-items: center; font-size: 12px; }
.mini-metric span { color: var(--text-muted); }
.mini-metric strong { color: var(--text); font-weight: 600; }

/* WORKFLOW */
.workflow-subtitle { margin: -6px 0 12px; color: var(--text-muted); font-size: 12px; }
.workflow-steps { display: grid; grid-template-columns: repeat(5,1fr); gap: 7px; margin-bottom: 10px; }
@media (max-width:1100px) { .workflow-steps { grid-template-columns: repeat(3,1fr); } }
.workflow-step { display: flex; flex-direction: column; align-items: center; gap: 4px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--surface); color: var(--text-muted); padding: 9px 7px; cursor: pointer; text-align: center; font-size: 11px; transition: all 0.12s; font-weight: 500; }
.workflow-step:hover { border-color: var(--primary); color: var(--primary); }
.workflow-step.done { border-color: #86efac; background: var(--success-bg); color: #166534; }
.workflow-progress { height: 5px; background: var(--border); border-radius: 999px; overflow: hidden; }
.workflow-progress-bar { height: 100%; background: linear-gradient(90deg,#2563eb,#0ea5e9); border-radius: 999px; transition: width 0.4s cubic-bezier(0.34,1.56,0.64,1); }

/* PERSONA */
.persona-kpi-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; margin-top: 10px; }
@media (max-width:900px) { .persona-kpi-grid { grid-template-columns: repeat(2,1fr); } }
.persona-insight-list { margin: 0; padding: 0; list-style: none; display: grid; gap: 5px; }
.persona-insight-list li { font-size: 12px; color: var(--text-muted); padding: 7px 9px; background: var(--surface-muted); border-radius: 5px; border-left: 3px solid var(--primary); }

/* PACK STATUS */
.pack-status { border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--surface-muted); color: var(--text-muted); padding: 7px 11px; font-size: 11px; }

.card-help {
  margin: -4px 0 10px;
  color: var(--text-muted);
  font-size: 12px;
}

.help-strip-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8px;
}

.help-pill {
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--surface-muted);
  padding: 8px 10px;
  display: grid;
  gap: 2px;
}

.help-pill strong {
  font-size: 11px;
  color: var(--text);
}

.help-pill span {
  font-size: 11px;
  color: var(--text-muted);
}

.doc-nav-btn {
  width: 100%;
  color: var(--text-muted);
  border: 1px solid var(--border);
  background: var(--surface);
}

.doc-nav-btn:hover {
  color: var(--primary);
  background: var(--surface-muted);
}

.doc-content {
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 14px;
  max-height: 70vh;
  overflow: auto;
  line-height: 1.55;
}

.doc-content h1,
.doc-content h2,
.doc-content h3 {
  margin-top: 0;
  color: var(--text);
}

.doc-content p,
.doc-content li {
  color: #334155;
  font-size: 13px;
}

.doc-content code {
  background: #f1f5f9;
  border-radius: 4px;
  padding: 1px 5px;
}

@media (max-width:1100px) {
  .help-strip-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width:700px) {
  .help-strip-grid {
    grid-template-columns: 1fr;
  }
}

/* EXPORT CARDS */
.export-cards { display: grid; grid-template-columns: repeat(auto-fill,minmax(160px,1fr)); gap: 9px; margin-bottom: 12px; }
.export-card { border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 13px; text-align: center; cursor: pointer; transition: all 0.12s; background: var(--surface); }
.export-card:hover { border-color: var(--primary); background: #f0f7ff; transform: translateY(-1px); }
.export-icon { font-size: 26px; margin-bottom: 6px; }
.export-label { font-size: 11px; font-weight: 600; color: var(--text); }
.export-desc { font-size: 10px; color: var(--text-muted); margin-top: 1px; }

/* PACK CARDS */
.pack-cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; }
.pack-card { border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 14px; transition: all 0.12s; }
.pack-card:hover { border-color: var(--primary); box-shadow: var(--shadow-sm); }
.pack-card-header { font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
.pack-files { font-size: 11px; color: var(--text-muted); margin: 3px 0 9px; }

/* HEALTH */
.health-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(190px,1fr)); gap: 9px; }
.health-card { border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 11px 13px; background: var(--surface); display: flex; align-items: center; gap: 9px; }
.health-icon { font-size: 20px; flex-shrink: 0; }
.health-name { font-size: 12px; font-weight: 600; }
.health-desc { font-size: 10px; color: var(--text-muted); }

/* STAT ROW */
.stat-row { display: flex; gap: 18px; flex-wrap: wrap; padding: 10px 0; border-bottom: 1px solid var(--border); }
.stat-item { display: flex; flex-direction: column; gap: 2px; }
.stat-value { font-size: 19px; font-weight: 700; color: var(--text); }
.stat-label { font-size: 10px; color: var(--text-muted); font-weight: 500; }

/* RANKED LIST */
.ranked-list { display: grid; gap: 5px; }
.ranked-item { display: grid; grid-template-columns: 26px 1fr auto auto; gap: 7px; align-items: center; padding: 7px 9px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--surface); font-size: 12px; }
.ranked-num { font-size: 10px; font-weight: 800; color: var(--text-faint); text-align: center; }
.ranked-name { font-weight: 500; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ranked-type { font-size: 10px; color: var(--text-muted); }
.ranked-score { font-weight: 700; font-size: 12px; color: var(--primary); text-align: right; }

/* RESULT BANNER */
.result-banner { display: flex; align-items: center; gap: 9px; padding: 9px 12px; border-radius: var(--radius-sm); font-size: 12px; font-weight: 500; }
.result-banner.success { background: var(--success-bg); color: #14532d; border: 1px solid #86efac; }
.result-banner.error   { background: var(--danger-bg);  color: #7f1d1d;  border: 1px solid #fca5a5; }
.result-banner.info    { background: var(--primary-light); color: #1e3a8a; border: 1px solid #93c5fd; }

/* CODE */
.mono { font-family: ui-monospace,SFMono-Regular,Menlo,Consolas,monospace; font-size: 12px; }
.code-block { background: #0f172a; color: #e2e8f0; border-radius: var(--radius-sm); padding: 11px 13px; font-family: ui-monospace,SFMono-Regular,Menlo,Consolas,monospace; font-size: 12px; overflow: auto; line-height: 1.6; }

/* TOAST */
.toast { position: fixed; bottom: 20px; right: 20px; background: #0f172a; color: #e2e8f0; padding: 9px 15px; border-radius: 10px; box-shadow: var(--shadow-lg); z-index: 10000; font-size: 12px; max-width: 360px; border-left: 3px solid var(--primary); animation: slideUp 0.2s ease; }
@keyframes slideUp { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }

/* MISC */
.empty { color: var(--text-faint); padding: 20px 0; text-align: center; font-size: 12px; }
.divider { border: none; border-top: 1px solid var(--border); margin: 12px 0; }
.text-muted { color: var(--text-muted); }
.text-small { font-size: 11px; }
.text-mono  { font-family: ui-monospace,SFMono-Regular,Menlo,Consolas,monospace; font-size: 12px; }
.flex-row { display: flex; align-items: center; gap: 7px; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.mt-4  { margin-top: 4px; }
.mt-8  { margin-top: 8px; }
.mt-12 { margin-top: 12px; }
.mt-16 { margin-top: 16px; }
.mb-8  { margin-bottom: 8px; }
.mb-12 { margin-bottom: 12px; }

/* Ensure full-width and height elements work */
#app-root, .v-app, .v-app__wrap {
  width: 100%;
  min-height: 100vh;
}

/* Vuetify overrides for responsive */
.v-container--fluid {
  padding: 0;
}

.v-container {
  width: 100%;
}

/* Vuetify readability + contrast baseline */
.v-field {
  background: #ffffff;
}

.v-field input,
.v-field textarea,
.v-field .v-select__selection,
.v-field .v-select__selection-text {
  color: var(--text) !important;
}

.v-field input::placeholder,
.v-field textarea::placeholder,
.v-field .v-label {
  color: var(--text-muted) !important;
  opacity: 0.95;
}

