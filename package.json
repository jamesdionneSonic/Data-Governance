{
  "name": "data-governance-platform",
  "version": "0.1.0",
  "description": "Enterprise data governance platform with markdown-driven lineage visualization",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node src/index.js",
    "start": "NODE_ENV=production node src/index.js",
    "build": "echo 'Build process for frontend would go here'",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --passWithNoTests",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "perf:load": "node scripts/perf-load-test.js",
    "lint": "eslint src tests --fix",
    "format": "prettier --write 'src/**/*.js' 'tests/**/*.js'",
    "check-framework": "node scripts/check-framework.js",
    "verify": "npm run lint && npm run test",
    "prepare": "husky install"
  },
  "keywords": [
    "data-governance",
    "lineage",
    "visualization",
    "markdown",
    "enterprise"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "archiver": "^8.0.0",
    "axios": "^1.6.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^11.1.1",
    "meilisearch": "^0.36.0",
    "morgan": "^1.10.0",
    "msnodesqlv8": "^5.1.9",
    "mssql": "^12.5.2",
    "uuid": "^9.0.1",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "cypress": "^13.6.2",
    "eslint": "^8.52.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3",
    "typescript": "^5.2.2"
  }
}
