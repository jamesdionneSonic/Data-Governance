{
  "name": "data-governance-platform",
  "version": "0.1.0",
  "description": "Enterprise data governance platform with markdown-driven lineage visualization",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node src/index.js",
    "start": "NODE_ENV=production node src/index.js",
    "build": "echo 'Build process for frontend would go here'",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --passWithNoTests",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "perf:load": "node scripts/perf-load-test.js",
    "lineage:brain": "node src/services/lineageBrain/runLineageBrain.js",
    "lineage:brain:check": "node scripts/check-lineage-brain.mjs",
    "catalog:rebuild:sample": "node scripts/rebuild-catalog-from-raw.mjs --dry-run --ssis-limit=100",
    "catalog:rebuild:dry": "node scripts/rebuild-catalog-from-raw.mjs --dry-run --enforce-gates",
    "catalog:rebuild": "node scripts/rebuild-catalog-from-raw.mjs --enforce-gates",
    "catalog:index": "node scripts/build-runtime-catalog-indexes.mjs",
    "catalog:dictionary:enrich": "node scripts/enrich-markdown-data-dictionary.mjs",
    "catalog:runtime:check": "node scripts/check-runtime-catalog.mjs",
    "catalog:repo:export": "node scripts/export-catalog-repo.mjs",
    "catalog:repo:check": "node scripts/check-catalog-repo.mjs",
    "catalog:refresh:repo": "npm run catalog:refresh:fast && npm run catalog:repo:export && npm run catalog:repo:check",
    "lineage:semantic:refresh": "node scripts/refresh-semantic-lineage-from-raw.mjs",
    "lineage:runtime:package": "node scripts/build-lineage-runtime-package.mjs",
    "lineage:runtime:check": "node scripts/check-lineage-runtime-package.mjs",
    "lineage:answers:check": "node scripts/check-lineage-answer-quality.mjs",
    "lineage:runtime:prepare": "npm run catalog:repo:export && npm run catalog:repo:check && npm run lineage:runtime:package && npm run lineage:runtime:check && npm run lineage:answers:check",
    "lineage:runtime:publish": "node scripts/publish-lineage-runtime-package.mjs",
    "catalog:refresh:fast": "npm run catalog:rebuild && npm run catalog:index && npm run catalog:runtime:check",
    "catalog:refresh": "npm run catalog:rebuild:sample && npm run catalog:rebuild:dry && npm run catalog:rebuild && npm run catalog:index && npm run catalog:runtime:check",
    "confluence:export": "node scripts/build-confluence-export.mjs",
    "confluence:check": "node scripts/check-confluence-export.mjs",
    "confluence:generated:check": "node scripts/check-confluence-generated-pages.mjs",
    "confluence:dry-run": "node scripts/sync-confluence-catalog.mjs",
    "confluence:sync": "node scripts/sync-confluence-catalog.mjs",
    "confluence:publish": "npm run confluence:export && npm run confluence:check && npm run confluence:dry-run && npm run confluence:sync -- --publish",
    "confluence:replace": "npm run confluence:export && npm run confluence:check && npm run confluence:dry-run && npm run confluence:sync -- --publish --replace-generated",
    "lineage:publish": "npm run catalog:refresh && npm run catalog:repo:export && npm run catalog:repo:check && npm run confluence:publish",
    "lineage:replace": "npm run catalog:refresh && npm run catalog:repo:export && npm run catalog:repo:check && npm run confluence:replace",
    "lint": "eslint src tests --fix",
    "format": "prettier --write 'src/**/*.js' 'tests/**/*.js'",
    "check-framework": "node scripts/check-framework.js",
    "verify": "npm run lint && npm run test",
    "prepare": "husky install"
  },
  "keywords": [
    "data-governance",
    "lineage",
    "visualization",
    "markdown",
    "enterprise"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@elastic/elasticsearch": "^9.4.0",
    "@playwright/test": "^1.54.2",
    "adm-zip": "^0.5.17",
    "archiver": "^8.0.0",
    "axios": "^1.6.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fast-xml-parser": "^5.7.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^11.1.1",
    "morgan": "^1.10.0",
    "mssql": "^12.5.2",
    "node-sql-parser": "^5.4.0",
    "uuid": "^9.0.1",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.52.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3",
    "typescript": "^5.2.2"
  },
  "optionalDependencies": {
    "msnodesqlv8": "^5.1.9"
  }
}
