# ============================================================================
# Application Environment
# ============================================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ============================================================================
# Meilisearch Configuration
# ============================================================================
# URL to Meilisearch instance
MEILISEARCH_URL=http://meilisearch:7700
# Master key for Meilisearch (change in production)
MEILISEARCH_MASTER_KEY=masterKeyForLocalDevelopmentOnly

# ============================================================================
# Entra ID / Microsoft Entra ID Configuration
# For development: Optional
# For production: Required for enterprise authentication
#
# Steps to get these values:
# 1. Go to https://portal.azure.com
# 2. Navigate to Azure Active Directory > App registrations
# 3. Create a new application registration
# 4. Copy the Application (client) ID and Directory (tenant) ID
# 5. Go to Certificates & secrets, create a new client secret
# ============================================================================
ENTRA_CLIENT_ID=your-client-id-here
ENTRA_CLIENT_SECRET=your-client-secret-here
ENTRA_TENANT_ID=your-tenant-id-here
ENTRA_REDIRECT_URI=http://localhost:3000/auth/callback

# ============================================================================
# JWT Configuration
# ============================================================================
# Secret key for signing JWT tokens (change in production!)
JWT_SECRET=dev-secret-key-change-in-production-12345
# Token expiry time (examples: 24h, 7d, 1w)
JWT_EXPIRY=24h
# Refresh token expiry time
REFRESH_TOKEN_EXPIRY=7d

# ============================================================================
# Data Path
# ============================================================================
MARKDOWN_DATA_PATH=./data/markdown
CATALOG_LOAD_MODE=summary
# Keep app startup/cache hydration from doing surprise heavy runtime-index builds.
CATALOG_RUNTIME_AUTO_REBUILD=false
# Explicit runtime index builds default to conservative concurrency to reduce OOM risk.
CATALOG_INDEX_BUILD_CONCURRENCY=2
CATALOG_DETAIL_CACHE_SIZE=200

# AI-readable DevOps catalog repository
CATALOG_REPO_PATH=../Sonic-data-lineage
CATALOG_REPO_REMOTE=https://sonicapplicationdevelopment@dev.azure.com/sonicapplicationdevelopment/Data%20Warehouse/_git/Sonic-data-lineage

# Azure Artifacts runtime package for AI/agent consumption
LINEAGE_RUNTIME_SOURCE_REPO=../Sonic-data-lineage
LINEAGE_RUNTIME_PACKAGE_ROOT=./data/lineage-runtime-package/sonic-data-lineage-runtime
LINEAGE_RUNTIME_PACKAGE_NAME=sonic-data-lineage-runtime
# Default generated package versions use a lowercase SemVer-like date, for example 2026.6.4-1.
LINEAGE_RUNTIME_PACKAGE_VERSION=
AZURE_ARTIFACTS_ORGANIZATION=https://dev.azure.com/sonicapplicationdevelopment
AZURE_ARTIFACTS_PROJECT=Data Warehouse
# Project-scoped Azure Artifacts feed for lineage runtime Universal Packages.
AZURE_ARTIFACTS_FEED=sonic-data-lineage-runtime

# ============================================================================
# Snowflake Connector: bipslyv / tlb12786
# ============================================================================
# Saved connector id: snowflake-bipslyv-tlb12786
# Account identifier derived from Snowsight URL:
# https://app.snowflake.com/bipslyv/tlb12786/
SNOWFLAKE_BIPSLYV_TLB12786_USERNAME=
SNOWFLAKE_BIPSLYV_TLB12786_PASSWORD=
SNOWFLAKE_BIPSLYV_TLB12786_WAREHOUSE=
SNOWFLAKE_BIPSLYV_TLB12786_DATABASE=
SNOWFLAKE_BIPSLYV_TLB12786_SCHEMA=PUBLIC
SNOWFLAKE_BIPSLYV_TLB12786_ROLE=

# ============================================================================
# Confluence Lineage Repository
# ============================================================================
# Used by npm run confluence:export and npm run confluence:sync.
# Do not commit live API tokens.
# See docs/CONFLUENCE_SPACE_MAP.md and src/config/confluencePageMap.js for the
# full Data Engineering landing-zone and publishing-root page map.
CONFLUENCE_BASE_URL=https://sonicautomotive.atlassian.net/wiki
CONFLUENCE_SPACE_KEY=TDE
# Publishing root: Sonic Data Lineage. Do not point this at the human landing hubs.
CONFLUENCE_PARENT_PAGE_ID=2221670415
CONFLUENCE_EXPORT_PATH=./data/confluence/export
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
# Dry-run is safe and does not require credentials.
CONFLUENCE_DRY_RUN=true
# Rovo-readable catalog pages group many objects per generated Confluence page.
CONFLUENCE_SHARD_OBJECT_LIMIT=150
CONFLUENCE_SHARD_MAX_BYTES=250000
CONFLUENCE_OBJECT_LOCATOR_OBJECT_LIMIT=500
CONFLUENCE_OBJECT_LOCATOR_MAX_BYTES=120000
CONFLUENCE_QUICK_CONTEXT_OBJECT_LIMIT=250
CONFLUENCE_QUICK_CONTEXT_MAX_BYTES=180000
CONFLUENCE_GOVERNED_OBJECT_PAGE_LIMIT=100
CONFLUENCE_PUBLISH_OBJECT_PAGES=true
CONFLUENCE_PUBLISH_ATTACHMENTS=true
CONFLUENCE_SYNC_CONCURRENCY=3
CONFLUENCE_ATTACHMENT_SYNC_CONCURRENCY=2
CONFLUENCE_HTTP_RETRIES=4
CONFLUENCE_HTTP_RETRY_BASE_MS=750
# Only use for intentional generated-page replacement after export/check/dry-run pass.
CONFLUENCE_REPLACE_GENERATED=false

# Publishing roots used by support-doc publishers.
# SSIS_CONFLUENCE_CATALOG_PAGE_ID=2269610019
# SSRS_CONFLUENCE_PARENT_PAGE_ID=2267643963

# ============================================================================
# Frontend Configuration (for CORS)
# ============================================================================
FRONTEND_URL=http://localhost:3001

