# ============================================================================
# Application Environment
# ============================================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ============================================================================
# Meilisearch Configuration
# ============================================================================
# URL to Meilisearch instance
MEILISEARCH_URL=http://meilisearch:7700
# Master key for Meilisearch (change in production)
MEILISEARCH_MASTER_KEY=masterKeyForLocalDevelopmentOnly

# ============================================================================
# Entra ID / Microsoft Entra ID Configuration
# For development: Optional
# For production: Required for enterprise authentication
#
# Steps to get these values:
# 1. Go to https://portal.azure.com
# 2. Navigate to Azure Active Directory > App registrations
# 3. Create a new application registration
# 4. Copy the Application (client) ID and Directory (tenant) ID
# 5. Go to Certificates & secrets, create a new client secret
# ============================================================================
ENTRA_CLIENT_ID=your-client-id-here
ENTRA_CLIENT_SECRET=your-client-secret-here
ENTRA_TENANT_ID=your-tenant-id-here
ENTRA_REDIRECT_URI=http://localhost:3000/auth/callback

# ============================================================================
# JWT Configuration
# ============================================================================
# Secret key for signing JWT tokens (change in production!)
JWT_SECRET=dev-secret-key-change-in-production-12345
# Token expiry time (examples: 24h, 7d, 1w)
JWT_EXPIRY=24h
# Refresh token expiry time
REFRESH_TOKEN_EXPIRY=7d

# ============================================================================
# Data Path
# ============================================================================
MARKDOWN_DATA_PATH=./data/markdown

# ============================================================================
# Frontend Configuration (for CORS)
# ============================================================================
FRONTEND_URL=http://localhost:3001

